---
import BaseLayout from '@/components/layout/BaseLayout.astro';
import { useTranslations, getLocalizedPath } from '@/i18n/ui';
import { tools } from '@/config/tools';

const lang = 'en';
const t = useTranslations(lang);
---

<BaseLayout title={`${t('tools.title')} - ${t('site.title')}`} description={t('tools.description')} lang={lang}>
  <section>
    <h2 class="text-3xl font-bold text-heading-light dark:text-heading-dark mb-3">
      {t('tools.title')}
    </h2>
    <div class="h-0.5 bg-gradient-to-r from-primary-light/40 via-slate-200 dark:via-white/10 to-transparent mb-8" />

    {tools.length > 0 ? (
      <div class="flex flex-col gap-5">
        {tools.map((tool) => (
          <a
            href={getLocalizedPath(`/tools/${tool.slug}/`, lang)}
            class="tool-card block group relative rounded-xl overflow-hidden
                   border border-slate-200/80 dark:border-white/[0.06]
                   hover:border-primary-light/40 dark:hover:border-primary-dark/40
                   hover:shadow-lg transition-all duration-300"
          >
            {/* Background image layer */}
            {tool.cover && (
              <div class="tool-card-bg absolute inset-0">
                <img
                  src={tool.cover}
                  alt=""
                  class="w-full h-full object-cover"
                  loading="lazy"
                  decoding="async"
                />
              </div>
            )}
            {/* Semi-transparent overlay */}
            <div class="absolute inset-0 bg-white/70 dark:bg-slate-900/75
                        group-hover:bg-white/60 dark:group-hover:bg-slate-900/65
                        transition-colors duration-300" />

            {/* Content */}
            <div class="relative z-10 flex items-center gap-5 p-6 sm:p-8">
              <div class="shrink-0 w-14 h-14 rounded-xl flex items-center justify-center
                          bg-primary-light/10 dark:bg-primary-dark/15
                          text-primary-light dark:text-primary-dark
                          group-hover:bg-primary-light/20 dark:group-hover:bg-primary-dark/25
                          group-hover:scale-105
                          transition-all duration-200">
                <svg class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="1.6" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="m21 12-9.75 9.75m9.75-9.75L3 12m18 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
                </svg>
              </div>
              <div class="flex-1 min-w-0">
                <h3 class="text-2xl font-semibold text-heading-light dark:text-heading-dark
                           group-hover:text-primary-light dark:group-hover:text-primary-dark
                           transition-colors mb-2">
                  {tool.name[lang]}
                </h3>
                <p class="text-text-light/70 dark:text-text-dark/70 text-base leading-relaxed">
                  {tool.description[lang]}
                </p>
              </div>
              <svg class="shrink-0 w-5 h-5 text-text-light/30 dark:text-text-dark/30
                          group-hover:text-primary-light dark:group-hover:text-primary-dark
                          group-hover:translate-x-1
                          transition-all duration-200"
                   fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
              </svg>
            </div>
          </a>
        ))}
      </div>
    ) : (
      <p class="rounded-xl border border-slate-200/80 dark:border-white/[0.08] bg-white/50 dark:bg-white/[0.02] px-5 py-8 text-center text-text-light/60 dark:text-text-dark/60">
        {t('tools.empty')}
      </p>
    )}
  </section>
</BaseLayout>

<style>
  .tool-card-bg img {
    transition: transform 0.5s ease;
  }
  .tool-card:hover .tool-card-bg img {
    transform: scale(1.04);
  }
</style>
