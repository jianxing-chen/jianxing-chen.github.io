---
import BaseLayout from '@/components/layout/BaseLayout.astro';
import PublicationCard from '@/components/ui/PublicationCard.astro';
import IconGithub from '@/components/ui/IconGithub.astro';
import IconOrcid from '@/components/ui/IconOrcid.astro';
import IconEmail from '@/components/ui/IconEmail.astro';
import { useTranslations, getLocalizedPath } from '@/i18n/ui';
import { SITE_CONFIG } from '@/config/site';
import papers from '@/content/publications/papers.json';
import newsData from '@/data/news.json';
import { getLocalizedText } from '@/utils/gallery';

import type { Paper } from '@/types/publication';
const typedPapers = papers as Paper[];

const lang = 'zh';
const t = useTranslations(lang);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const sortedNews = [...newsData].sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());

const researchInterests = [
  '白矮星',
  '球状星团',
  '测光',
  '变星',
  '毫秒脉冲星',
];

const experience = [
  {
    title: '励耘博士后',
    org: '北京师范大学物理与天文学院',
    years: '2024 – 至今',
    desc: '利用 HST 测光研究球状星团中的白矮星冷却序列与奇特双星系统。',
  },
  {
    title: '研究员',
    org: '博洛尼亚大学物理与天文学系',
    years: '2023 – 2024',
    desc: '研究银河系球状星团中的恒星族。',
  },
];

const grants = [
  {
    title: '国家自然科学基金青年科学基金项目（C类）',
    number: 'No. 12503036',
    years: '2026 – 2028',
    role: 'pi' as const,
  },
  {
    title: '中国博士后科学基金第76批面上项目',
    number: 'No. 2024M760242',
    years: '2024 – 2026',
    role: 'pi' as const,
  },
  {
    title: '国家资助博士后研究人员计划（C 档）',
    number: 'No. GZC20240124',
    years: '2024 – 2026',
    role: 'pi' as const,
  },
  {
    title: '博洛尼亚大学研究生科研活动基金',
    years: '2022',
    role: 'pi' as const,
  },
  {
    title: '博洛尼亚大学马可·波罗基金',
    years: '2022',
    role: 'pi' as const,
  },
  {
    title: '国家自然科学基金重点项目 — Kepler 天区脉动变星星震学研究',
    number: 'No. 1183000094',
    years: '2019 – 2023',
    role: 'co-i' as const,
  },
  {
    title: '北京市自然科学基金 — LAMOST 与 Kepler 高振幅 δ Scuti 星星震学',
    number: 'No. 1194023',
    years: '2019 – 2020',
    role: 'co-i' as const,
  },
];

const observations = [
  { telescope: 'HST', desc: 'GO 17763 — 校准白矮星冷却计时器：残余热核燃烧的影响', url: 'https://ui.adsabs.harvard.edu/abs/2024hst..prop17763F/abstract' },
  { telescope: '兴隆 2.16m', desc: '中国科学院国家天文台', url: 'http://www.xinglong-naoc.cn/html/gcyq/216/detail-15.html' },
  { telescope: '兴隆 85cm', desc: '中国科学院国家天文台', url: 'http://www.xinglong-naoc.cn/html/gcyq/85/' },
  { telescope: '南山 1m', desc: '中国科学院新疆天文台', url: 'http://www.xao.ac.cn/gcsb/ns1m/' },
  { telescope: '丽江 2.4m', desc: '中国科学院云南天文台', url: 'https://sao.ynao.ac.cn/equipment/2-4m-telescope' },
  { telescope: 'SPM 85cm', desc: '墨西哥圣佩德罗马尔蒂尔山国家天文台', url: 'https://astronomia.unam.mx/observatorio-spm/' },
];

const outreach = [
  {
    type: 'award',
    title: '公众超新星搜寻项目发现奖',
    org: 'XMO & 中国虚拟天文台',
    year: '2018',
    url: 'https://nadc.china-vo.org/psp/article/20190202143814',
  },
  {
    type: 'award',
    title: '公众超新星搜寻项目新人奖',
    org: 'XMO & 中国虚拟天文台',
    year: '2018',
    url: 'https://nadc.china-vo.org/psp/article/20190202143814',
  },
  {
    type: 'article',
    title: '我发现的第⼀颗超新星',
    org: '《天文爱好者》，2015 年 12 月',
    year: '2015',
    url: 'https://nadc.china-vo.org/psp/article/20221129113818',
  },
];
---

<BaseLayout title={`${t('about.title')} - ${t('site.title')}`} description="陈剑星 — 天体物理学家，专注于恒星演化、球状星团与白矮星研究。简历、论文与联系方式。" lang={lang}>
  <article class="space-y-16">

    <!-- ====== Hero ====== -->
    <section class="flex flex-col sm:flex-row items-center sm:items-start gap-8">
      <!-- Avatar -->
      <div class="shrink-0">
        <div class="w-40 h-40 rounded-full overflow-hidden shadow-lg ring-4 ring-primary-light/20 dark:ring-primary-dark/20">
          <img
            src={`${base}/images/avatar.jpg`}
            alt={SITE_CONFIG.author.zh}
            width="160"
            height="160"
            class="w-full h-full object-cover"
            style="aspect-ratio:1;"
            onerror="this.style.background='#b8c9dc';this.alt='头像'"
          />
        </div>
      </div>
      <!-- Info -->
      <div class="text-center sm:text-left space-y-3">
        <h1 class="text-3xl sm:text-4xl font-bold text-heading-light dark:text-heading-dark">
          {SITE_CONFIG.author.zh}
        </h1>
        <p class="text-lg text-primary-light dark:text-primary-dark font-medium">
          {SITE_CONFIG.position.zh}
        </p>
        <p class="text-text-light/70 dark:text-text-dark/70">
          {SITE_CONFIG.affiliation.zh}
        </p>
        {/* Research Interests in Hero */}
        <div class="flex flex-wrap gap-2 justify-center sm:justify-start">
          {researchInterests.map((tag) => (
            <span class="px-3 py-1 rounded-full text-xs font-medium bg-primary-light/10 text-primary-light dark:bg-primary-dark/15 dark:text-primary-dark border border-primary-light/20 dark:border-primary-dark/25">
              {tag}
            </span>
          ))}
        </div>
      </div>
    </section>

    <!-- ====== 第一部分：个人简历 ====== -->
    <section id="cv" style="scroll-margin-top: 5rem;">
      <h2 class="text-3xl font-bold text-heading-light dark:text-heading-dark mb-3">
        {t('about.section.cv')}
      </h2>
      <div class="h-0.5 bg-gradient-to-r from-primary-light/40 via-slate-200 dark:via-white/10 to-transparent mb-10" />

    <!-- ====== Experience ====== -->
    <section>
      <h2 class="text-2xl font-bold text-heading-light dark:text-heading-dark mb-8">
        {t('about.experience')}
      </h2>
      <div class="experience-timeline relative pl-8 space-y-10">
        {experience.map((item) => (
          <div class="relative">
            <div class="absolute -left-[calc(2rem+2px)] top-[0.5rem] w-1.5 h-1.5 rounded-full bg-primary-light dark:bg-primary-dark ring-2 ring-background-light dark:ring-background-dark" />
            <p class="text-sm text-text-light/50 dark:text-text-dark/50 font-mono mb-1">{item.years}</p>
            <h3 class="text-lg font-semibold text-heading-light dark:text-heading-dark">{item.title}</h3>
            <p class="text-text-light/80 dark:text-text-dark/80">{item.org}</p>
            <p class="text-sm text-text-light/60 dark:text-text-dark/60 mt-1">{item.desc}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- ====== 基金与资助 ====== -->
    <section class="mt-14">
      <h2 class="text-2xl font-bold text-heading-light dark:text-heading-dark mb-6">
        {t('about.grants')}
      </h2>
      <ul class="space-y-4">
        {grants.map((item) => (
          <li class="flex items-start gap-3">
            <span class="shrink-0 w-28 text-sm font-mono text-primary-light dark:text-primary-dark mt-0.5">{item.years}</span>
            <div class="flex-1 min-w-0">
              <span class="text-text-light/80 dark:text-text-dark/80">{item.title}</span>
              {item.number && (
                <span class="ml-2 text-xs font-mono text-text-light/40 dark:text-text-dark/40">{item.number}</span>
              )}
            </div>
            <span class="shrink-0 text-xs font-medium px-2 py-0.5 rounded-full border bg-slate-100 text-slate-500 border-slate-200 dark:bg-white/[0.05] dark:text-slate-400 dark:border-white/10">
              {item.role === 'pi' ? '主持' : '参与'}
            </span>
          </li>
        ))}
      </ul>
    </section>

    <!-- ====== 观测设施 ====== -->
    <section class="mt-14">
      <h2 class="text-2xl font-bold text-heading-light dark:text-heading-dark mb-6">
        {t('about.observations')}
      </h2>
      <ul class="space-y-3">
        {observations.map((item) => (
          <li class="flex items-start gap-3">
            <span class="shrink-0 text-sm font-mono text-primary-light dark:text-primary-dark mt-0.5 min-w-[8rem]">{item.telescope}</span>
            <a href={item.url} target="_blank" rel="noopener noreferrer" class="text-text-light/80 dark:text-text-dark/80 hover:text-primary-light dark:hover:text-primary-dark transition-colors">{item.desc}</a>
          </li>
        ))}
      </ul>
    </section>

    <!-- ====== 科普 Outreach ====== -->
    <section class="mt-14">
      <h2 class="text-2xl font-bold text-heading-light dark:text-heading-dark mb-6">
        {t('about.outreach')}
      </h2>
      <ul class="space-y-3">
        {outreach.map((item) => (
          <li class="flex items-start gap-3">
            <span class="shrink-0 text-sm font-mono text-primary-light dark:text-primary-dark mt-0.5">{item.year}</span>
            <div>
              <span class="text-xs font-medium uppercase text-accent-light dark:text-accent-dark">{item.type === 'award' ? '🏆' : '📝'}</span>
              <a href={item.url} target="_blank" rel="noopener noreferrer"
                 class="text-text-light/80 dark:text-text-dark/80 hover:text-primary-light dark:hover:text-primary-dark transition-colors">
                {item.title}
              </a>
              <span class="ml-2 text-xs text-text-light/40 dark:text-text-dark/40">{item.org}</span>
            </div>
          </li>
        ))}
      </ul>
    </section>

    </section><!-- end CV -->

    <!-- ====== 第二部分：发表论文 ====== -->
    <section id="publications" style="scroll-margin-top: 5rem;">
      <h2 class="text-3xl font-bold text-heading-light dark:text-heading-dark mb-3">
        {t('about.section.publications')}
      </h2>
      <div class="h-0.5 bg-gradient-to-r from-primary-light/40 via-slate-200 dark:via-white/10 to-transparent mb-10" />

      {/* Three collapsible sub-sections */}
      <div class="space-y-6">
        {[
          {
            label: t('about.publications.first_corresponding'),
            papers: typedPapers.filter((p) => p.type === 'first-author' || p.type === 'corresponding').sort((a, b) => b.year - a.year),
          },
          {
            label: t('about.publications.significant'),
            papers: typedPapers.filter((p) => p.type === 'co-author' && p.highlight).sort((a, b) => b.year - a.year),
          },
          {
            label: t('about.publications.participating'),
            papers: typedPapers.filter((p) => p.type === 'co-author' && !p.highlight).sort((a, b) => b.year - a.year),
          },
        ].map((category) => (
          <details open class="group border border-slate-200/80 dark:border-white/[0.06] rounded-xl bg-white/40 dark:bg-white/[0.02] transition-all duration-200">
            <summary class="flex items-center justify-between px-5 py-3.5 cursor-pointer select-none hover:bg-black/[0.02] dark:hover:bg-white/[0.02] rounded-xl transition-colors">
              <h3 class="text-lg font-semibold text-heading-light dark:text-heading-dark">
                {category.label}
                <span class="ml-2.5 text-sm font-normal text-text-light/50 dark:text-text-dark/50">
                  ({category.papers.length})
                </span>
              </h3>
              <svg class="w-4 h-4 text-text-light/40 dark:text-text-dark/40 transition-transform duration-200 group-open:rotate-180 shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="px-5 pb-5 space-y-3">
              {category.papers.length === 0 ? (
                <p class="text-sm text-text-light/40 dark:text-text-dark/40 py-4 text-center">{t('publications.empty')}</p>
              ) : (
                category.papers.map((paper) => (
                  <PublicationCard paper={paper} lang={lang} />
                ))
              )}
            </div>
          </details>
        ))}
      </div>
    </section>

    <!-- ====== 第三部分：新闻报道 ====== -->
    <section id="news" style="scroll-margin-top: 5rem;">
      <h2 class="text-3xl font-bold text-heading-light dark:text-heading-dark mb-3">{t('about.section.news')}</h2>
      <div class="h-0.5 bg-gradient-to-r from-primary-light/40 via-slate-200 dark:via-white/10 to-transparent mb-10" />
      <div class="space-y-4">
        {sortedNews.filter((item) => item.highlight).slice(0, 5).map((item) => (
          <a href={item.url} target="_blank" rel="noopener noreferrer"
             class="block p-4 rounded-lg border border-border-light dark:border-border-dark hover:border-primary-light dark:hover:border-primary-dark transition-colors group">
            <div class="flex items-start justify-between gap-4">
              <div class="flex-1 min-w-0">
                <h3 class="text-lg font-medium text-text-light dark:text-text-dark group-hover:text-primary-light dark:group-hover:text-primary-dark transition-colors">
                  {item.title[lang]}
                </h3>
                <div class="flex items-center gap-2 mt-1 text-sm text-text-light/60 dark:text-text-dark/60">
                  <span>{getLocalizedText(item.source, lang)}</span>
                  <span>·</span>
                  <time datetime={item.date}>{new Date(item.date).toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
                </div>
              </div>
              {item.type && (
                <span class="shrink-0 mt-1 px-2 py-0.5 rounded-full text-[11px] font-medium border text-text-light/40 dark:text-text-dark/40 border-text-light/15 dark:border-text-dark/15">
                  {item.type === 'talk' ? t('news.type.talk') : t('news.type.media')}
                </span>
              )}
            </div>
          </a>
        ))}
      </div>

      {/* More link */}
      <div class="mt-6 text-center">
        <a
          href={getLocalizedPath('/about/news', lang)}
          class="inline-flex items-center gap-1.5 px-5 py-2.5 rounded-lg text-sm font-medium
                 bg-primary-light/8 dark:bg-primary-dark/10
                 text-primary-light dark:text-primary-dark
                 hover:bg-primary-light/15 dark:hover:bg-primary-dark/20
                 transition-colors duration-200"
        >
          {t('about.news.more')}
        </a>
      </div>
    </section>

    <!-- ====== 第四部分：联系方式 ====== -->
    <section id="contact" style="scroll-margin-top: 5rem;">
      <h2 class="text-3xl font-bold text-heading-light dark:text-heading-dark mb-3">
        {t('about.section.contact')}
      </h2>
      <div class="h-0.5 bg-gradient-to-r from-primary-light/40 via-slate-200 dark:via-white/10 to-transparent mb-10" />
      <div class="grid sm:grid-cols-2 gap-4 text-sm">
        <div class="flex items-start gap-3">
          <IconEmail class="w-5 h-5 mt-0.5 shrink-0 text-primary-light dark:text-primary-dark" />
          <div>
            <p class="font-medium text-heading-light dark:text-heading-dark">Email</p>
            <a href={SITE_CONFIG.social.email} class="text-primary-light dark:text-primary-dark hover:underline">jxchen_cn@outlook.com</a>
          </div>
        </div>
        <div class="flex items-start gap-3">
          <svg class="w-5 h-5 mt-0.5 shrink-0 text-primary-light dark:text-primary-dark" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" /><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" /></svg>
          <div>
            <p class="font-medium text-heading-light dark:text-heading-dark">{t('about.office_address')}</p>
            <p class="text-text-light/70 dark:text-text-dark/70">北京市海淀区新街口外大街 19 号<br/>北京，100875</p>
          </div>
        </div>
        <div class="flex items-start gap-3">
          <IconGithub class="w-5 h-5 mt-0.5 shrink-0 text-primary-light dark:text-primary-dark" />
          <div>
            <p class="font-medium text-heading-light dark:text-heading-dark">GitHub</p>
            <a href={SITE_CONFIG.social.github} target="_blank" rel="noopener noreferrer" class="text-primary-light dark:text-primary-dark hover:underline">github.com/jianxing-chen</a>
          </div>
        </div>
        <div class="flex items-start gap-3">
          <IconOrcid class="w-5 h-5 mt-0.5 shrink-0 text-primary-light dark:text-primary-dark" />
          <div>
            <p class="font-medium text-heading-light dark:text-heading-dark">ORCID</p>
            <a href={SITE_CONFIG.social.orcid} target="_blank" rel="noopener noreferrer" class="text-primary-light dark:text-primary-dark hover:underline">0000-0002-8004-549X</a>
          </div>
        </div>
      </div>
    </section>

    <!-- ====== CV Download (hidden) ======
    <section class="text-center pt-4">
      <a
        href={`${base}/cv.pdf`}
        download
        class="inline-flex items-center gap-2 px-8 py-3 rounded-lg bg-primary-light dark:bg-primary-dark text-white font-semibold text-base shadow-md hover:shadow-lg hover:scale-[1.02] active:scale-[0.98] transition-all duration-200"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5M16.5 12 12 16.5m0 0L7.5 12m4.5 4.5V3" /></svg>
        {t('about.download_cv')}
      </a>
    </section>
    -->

  </article>
</BaseLayout>

<style>
  .experience-timeline::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.3rem;
    bottom: 0.3rem;
    width: 2px;
    background: linear-gradient(
      to bottom,
      transparent,
      rgb(59 130 246 / 0.08) 30%,
      rgb(59 130 246 / 0.35)
    );
  }

  :global(.dark) .experience-timeline::before {
    background: linear-gradient(
      to bottom,
      transparent,
      rgb(96 165 250 / 0.08) 30%,
      rgb(96 165 250 / 0.35)
    );
  }
</style>
