---
import BaseLayout from '@/components/layout/BaseLayout.astro';

const lang = 'en';
---

<BaseLayout title="Search" description="Search across blog posts, research, catalogs, and publications." lang={lang}>
  <div class="max-w-3xl mx-auto">
    <h1 class="text-3xl font-bold font-heading text-heading-light dark:text-heading-dark mb-2">
      Search
    </h1>
    <p class="text-muted-light dark:text-muted-dark mb-8">
      Search across blog posts, research, catalogs, and publications.
    </p>

    <!-- Search input -->
    <div class="search-box relative mb-10">
      <input
        id="search-input"
        type="text"
        placeholder="Type to search..."
        class="w-full px-5 py-3.5 pl-12 rounded-xl
               bg-white dark:bg-slate-800
               border border-slate-200 dark:border-white/10
               text-text-light dark:text-text-dark
               placeholder:text-muted-light dark:placeholder:text-muted-dark
               text-lg focus:outline-none focus:ring-2 focus:ring-primary-light/40
               dark:focus:ring-primary-dark/40
               shadow-sm"
        autofocus
      />
      <svg class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-muted-light dark:text-muted-dark"
           fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round"
              d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" />
      </svg>
    </div>

    <!-- Results -->
    <div id="search-results" class="space-y-4" aria-live="polite">
      <p class="text-center text-muted-light dark:text-muted-dark py-12">
        Start typing to see results…
      </p>
    </div>
  </div>
</BaseLayout>

<script is:inline>
  (async function() {
    var input = document.getElementById('search-input');
    var results = document.getElementById('search-results');
    if (!input || !results) return;

    var pagefind = null;
    try {
      pagefind = await import('/pagefind/pagefind.js');
      await pagefind.init();
    } catch (e) {
      pagefind = null;
    }
    if (!pagefind) {
      results.innerHTML = '<p class="text-center text-muted-light dark:text-muted-dark py-12">Search is not available. Please try again later.</p>';
      return;
    }

    var debounceTimer;

    function highlightExcerpt(html) {
      var div = document.createElement('div');
      div.innerHTML = html;
      div.querySelectorAll('mark').forEach(function(m) {
        m.className = 'bg-amber-200 dark:bg-amber-700 text-inherit rounded-sm px-0.5';
      });
      return div.innerHTML;
    }

    input.addEventListener('input', function() {
      clearTimeout(debounceTimer);
      var query = input.value.trim();
      if (query.length < 2) {
        results.innerHTML = '<p class="text-center text-muted-light dark:text-muted-dark py-12">Start typing to see results…</p>';
        return;
      }
      debounceTimer = setTimeout(async function() {
        results.innerHTML = '<p class="text-center text-muted-light dark:text-muted-dark py-12">Searching…</p>';
        try {
          var search = await pagefind.search(query);
          if (!search || !search.results.length) {
            results.innerHTML = '<p class="text-center text-muted-light dark:text-muted-dark py-12">No results found. Try a different query.</p>';
            return;
          }
          var parts = [];
          for (var i = 0; i < search.results.slice(0, 20).length; i++) {
            var data = await search.results[i].data();
            var excerpt = data.excerpt ? highlightExcerpt(data.excerpt) : '';
            parts.push(
              '<a href="' + data.url + '" class="block p-5 rounded-xl' +
              ' bg-white/70 dark:bg-white/[0.03]' +
              ' border border-slate-200/60 dark:border-white/[0.05]' +
              ' hover:border-primary-light/30 dark:hover:border-primary-dark/30' +
              ' hover:shadow-sm transition-all duration-200">' +
              '<h3 class="text-base font-semibold text-heading-light dark:text-heading-dark mb-1.5">' +
              (data.meta.title || 'Untitled') + '</h3>' +
              (excerpt ? '<p class="text-sm text-text-light/70 dark:text-text-dark/70 leading-relaxed mb-1.5">' + excerpt + '</p>' : '') +
              '<div class="flex items-center gap-3 text-xs text-muted-light dark:text-muted-dark">' +
              (data.meta.kind ? '<span class="uppercase tracking-wider">' + data.meta.kind + '</span>' : '') +
              (data.meta.lang ? '<span>' + (data.meta.lang === 'zh' ? '中文' : 'English') + '</span>' : '') +
              '</div></a>'
            );
          }
          results.innerHTML = parts.join('');
        } catch (err) {
          console.error('Pagefind search error:', err);
          results.innerHTML = '<p class="text-center text-muted-light dark:text-muted-dark py-12">An error occurred while searching. Please try again.</p>';
        }
      }, 250);
    });
  })();
</script>
