---
import BaseLayout from '@/components/layout/BaseLayout.astro';
import ProjectCard from '@/components/ui/ProjectCard.astro';
import { useTranslations, getLocalizedPath } from '@/i18n/ui';
import { getCollection } from 'astro:content';

const lang = 'en';
const t = useTranslations(lang);

const allResearch = await getCollection('research');
const projects = allResearch
  .filter((p) => p.id.startsWith('en/'))
  .sort((a, b) => (a.data.order ?? 0) - (b.data.order ?? 0));

const allCatalogs = await getCollection('catalogs');
const catalogs = allCatalogs.filter((c) => c.id.startsWith('en/'));
---

<BaseLayout title={`${t('research.title')} - ${t('site.title')}`} description={t('research.description')} lang={lang}>
  <div class="mb-10">
    <h1 class="text-3xl sm:text-4xl font-bold text-heading-light dark:text-heading-dark mb-3">
      {t('research.title')}
    </h1>
    <p class="text-lg text-text-light/70 dark:text-text-dark/70 max-w-2xl">
      {t('research.description')}
    </p>
  </div>

  {/* Filter buttons */}
  <div class="flex gap-2 mb-8" id="filter-bar">
    <button data-filter="all"
      class="filter-btn active px-4 py-1.5 text-sm font-medium rounded-full transition-colors duration-200
             bg-primary-light text-white dark:bg-primary-dark dark:text-slate-900">
      {t('research.all')}
    </button>
    <button data-filter="ongoing"
      class="filter-btn px-4 py-1.5 text-sm font-medium rounded-full transition-colors duration-200
             bg-slate-100 text-slate-600 dark:bg-slate-700 dark:text-slate-300
             hover:bg-slate-200 dark:hover:bg-slate-600">
      {t('research.ongoing')}
    </button>
    <button data-filter="completed"
      class="filter-btn px-4 py-1.5 text-sm font-medium rounded-full transition-colors duration-200
             bg-slate-100 text-slate-600 dark:bg-slate-700 dark:text-slate-300
             hover:bg-slate-200 dark:hover:bg-slate-600">
      {t('research.completed')}
    </button>
  </div>

  {/* Project grid */}
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6" id="project-grid">
    {projects.map((project) => {
      const slug = project.id.replace('en/', '');
      return (
        <div class="project-item" data-status={project.data.status}>
          <ProjectCard
            title={project.data.title}
            description={project.data.description}
            cover={project.data.cover}
            status={project.data.status}
            tags={project.data.tags}
            href={getLocalizedPath(`/research/${slug}`, lang)}
            statusLabel={project.data.status === 'ongoing' ? t('research.ongoing') : t('research.completed')}
          />
        </div>
      );
    })}
  </div>

  {/* Catalogs section */}
  <hr class="my-12 border-gray-200 dark:border-gray-700/50" />

  <section id="catalogs">
    <h2 class="text-2xl sm:text-3xl font-bold text-heading-light dark:text-heading-dark mb-6">
      {t('research.data_catalogs')}
    </h2>

    <div class="grid gap-6">
      {catalogs.map((catalog) => {
        const slug = catalog.id.replace('en/', '');
        return (
          <a
            href={getLocalizedPath(`/catalogs/${slug}`, lang)}
            class="block group border border-gray-200 dark:border-gray-700/50 rounded-xl p-6
                   hover:border-primary-light dark:hover:border-primary-dark
                   hover:shadow-md transition-all duration-200
                   bg-white/50 dark:bg-white/[0.02]"
          >
            <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4">
              <div class="flex-1 min-w-0">
                <h3 class="text-xl font-semibold text-heading-light dark:text-heading-dark
                           group-hover:text-primary-light dark:group-hover:text-primary-dark
                           transition-colors mb-2">
                  {catalog.data.title}
                </h3>
                <p class="text-text-light/70 dark:text-text-dark/70 text-sm leading-relaxed">
                  {catalog.data.description}
                </p>
                <div class="flex flex-wrap gap-4 mt-3 text-xs text-text-light/50 dark:text-text-dark/50">
                  {catalog.data.rows && (
                    <span class="inline-flex items-center gap-1">
                      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v18"/><path d="M3 12h18"/><rect x="3" y="3" width="18" height="18" rx="2"/></svg>
                      {catalog.data.rows} {t('catalogs.rows')}
                    </span>
                  )}
                  {catalog.data.version && (
                    <span class="inline-flex items-center gap-1">
                      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 8v4l3 3"/><circle cx="12" cy="12" r="10"/></svg>
                      v{catalog.data.version}
                    </span>
                  )}
                </div>
              </div>
            </div>
          </a>
        );
      })}
    </div>

    {catalogs.length === 0 && (
      <p class="text-center text-text-light/50 dark:text-text-dark/50 py-12">
        No catalogs available yet.
      </p>
    )}
  </section>
</BaseLayout>

<script>
  function initFilter() {
    const buttons = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
    const items = document.querySelectorAll<HTMLElement>('.project-item');

    const activeClasses = ['bg-primary-light', 'text-white', 'dark:bg-primary-dark', 'dark:text-slate-900'];
    const inactiveClasses = ['bg-slate-100', 'text-slate-600', 'dark:bg-slate-700', 'dark:text-slate-300', 'hover:bg-slate-200', 'dark:hover:bg-slate-600'];

    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const filter = btn.dataset.filter;

        buttons.forEach((b) => {
          b.classList.remove(...activeClasses, 'active');
          b.classList.add(...inactiveClasses);
        });
        btn.classList.remove(...inactiveClasses);
        btn.classList.add(...activeClasses, 'active');

        items.forEach((item) => {
          if (filter === 'all' || item.dataset.status === filter) {
            item.style.display = '';
          } else {
            item.style.display = 'none';
          }
        });
      });
    });
  }

  initFilter();
  document.addEventListener('astro:after-swap', initFilter);
</script>
