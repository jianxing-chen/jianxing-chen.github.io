---
import BaseLayout from '@/components/layout/BaseLayout.astro';
import { useTranslations, getLocalizedPath } from '@/i18n/ui';
import { extractSlug } from '@/utils/slug';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const allResearch = await getCollection('research');
  return allResearch
    .filter((p) => p.id.startsWith('en/'))
    .map((project) => ({
      params: { slug: extractSlug(project.id) },
      props: { project },
    }));
}

const lang = 'en';
const t = useTranslations(lang);
const { project } = Astro.props;
const { Content } = await render(project);

const isOngoing = project.data.status === 'ongoing';
---

<BaseLayout title={`${project.data.title} - ${t('site.title')}`} description={project.data.description} lang={lang}>
  {/* Back link */}
  <a href={getLocalizedPath('/research', lang)}
    class="inline-flex items-center gap-1.5 text-sm text-text-light/60 dark:text-text-dark/60
           hover:text-primary-light dark:hover:text-primary-dark transition-colors mb-6">
    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
    </svg>
    {t('research.back_to_list')}
  </a>

  {/* Cover */}
  {project.data.cover && (
    <div class="rounded-xl overflow-hidden mb-8 aspect-video">
      <img src={project.data.cover} alt={project.data.title} class="w-full h-full object-cover" />
    </div>
  )}

  {/* Header */}
  <div class="mb-8">
    <div class="flex flex-wrap items-center gap-3 mb-4">
      <span class:list={[
        'inline-flex items-center px-3 py-1 rounded-full text-sm font-medium',
        isOngoing
          ? 'bg-emerald-100 text-emerald-700 dark:bg-emerald-900/30 dark:text-emerald-400'
          : 'bg-slate-100 text-slate-600 dark:bg-slate-700 dark:text-slate-400',
      ]}>
        <span class:list={[
          'w-2 h-2 rounded-full mr-2',
          isOngoing ? 'bg-emerald-500' : 'bg-slate-400 dark:bg-slate-500',
        ]}></span>
        {isOngoing ? t('research.ongoing') : t('research.completed')}
      </span>
    </div>

    <h1 class="text-3xl sm:text-4xl font-bold text-heading-light dark:text-heading-dark mb-4">
      {project.data.title}
    </h1>

    <p class="text-lg text-text-light/70 dark:text-text-dark/70 mb-4">
      {project.data.description}
    </p>

    {/* Tags */}
    <div class="flex flex-wrap gap-2">
      {project.data.tags.map((tag: string) => (
        <span class="inline-block px-3 py-1 text-sm rounded-md
                      bg-slate-100 text-slate-600
                      dark:bg-slate-700/60 dark:text-slate-400">
          {tag}
        </span>
      ))}
    </div>
  </div>

  {/* Content */}
  <article class="prose prose-slate dark:prose-invert max-w-3xl
                   prose-headings:text-heading-light dark:prose-headings:text-heading-dark
                   prose-a:text-primary-light dark:prose-a:text-primary-dark
                   prose-strong:text-heading-light dark:prose-strong:text-heading-dark">
    <Content />
  </article>

  {/* Related papers placeholder */}
  <div class="mt-12 pt-8 border-t border-slate-200 dark:border-slate-700/50 max-w-3xl">
    <h2 class="text-xl font-semibold text-heading-light dark:text-heading-dark mb-4">
      {t('research.related_papers')}
    </h2>
    <p class="text-sm text-text-light/50 dark:text-text-dark/50 italic">
      Related publications will be linked here once available.
    </p>
  </div>
</BaseLayout>
