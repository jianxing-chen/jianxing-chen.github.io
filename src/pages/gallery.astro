---
import BaseLayout from '@/components/layout/BaseLayout.astro';
import GalleryGrid from '@/components/ui/GalleryGrid.astro';
import { useTranslations } from '@/i18n/ui';
import photos from '@/data/gallery.json';

const lang = 'en';
const t = useTranslations(lang);
---

<BaseLayout title={`${t('gallery.title')} - ${t('site.title')}`} description={t('gallery.description')} lang={lang}>
  <div class="max-w-6xl mx-auto -mx-4 sm:-mx-6 px-4 sm:px-6">
    <div class="mb-8">
      <h1 class="text-3xl sm:text-4xl font-bold text-heading-light dark:text-heading-dark mb-3">
        {t('gallery.title')}
      </h1>
      <p class="text-text-light/70 dark:text-text-dark/70 text-base sm:text-lg">
        {t('gallery.description')}
      </p>
      <p class="text-sm text-text-light/50 dark:text-text-dark/50 mt-2">
        {photos.length} {t('gallery.photo_count')}
      </p>
    </div>

    <GalleryGrid photos={photos} lang={lang} />
  </div>
</BaseLayout>
