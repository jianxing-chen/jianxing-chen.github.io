---
import BaseLayout from '@/components/layout/BaseLayout.astro';
import GalleryGrid from '@/components/ui/GalleryGrid.astro';
import { useTranslations, getLocalizedPath } from '@/i18n/ui';
import photos from '@/data/gallery.json';
import { slugifyCountry } from '@/utils/gallery';

// Generate all country pages at build time
export function getStaticPaths() {
  const countries = [...new Set(photos.map((p) => p.location.en))];
  return countries.map((c) => ({
    params: { country: slugifyCountry(c) },
  }));
}

const lang = 'en';
const t = useTranslations(lang);

const { country } = Astro.params;
const countrySlug = country!;

const countryPhotos = photos.filter((p) => slugifyCountry(p.location.en) === countrySlug);

const countryDisplay = countryPhotos.length > 0
  ? countryPhotos[0].location.en
  : countrySlug;
const backHref = getLocalizedPath(`/gallery/#country-${countrySlug}`, lang);
---

<BaseLayout title={`${countryDisplay} Photos - ${t('site.title')}`} lang={lang}>
  <div class="max-w-[90rem] mx-auto px-4 sm:px-6">
    <div class="mb-10 sm:mb-12">
      <a href={backHref} class="text-sm text-primary-light dark:text-primary-dark hover:underline mb-4 inline-block">
        ← {t('gallery.back_to_gallery')}
      </a>
      <h1 class="text-3xl sm:text-4xl font-bold text-heading-light dark:text-heading-dark mb-3">
        {countryDisplay}
      </h1>
      <p class="text-sm text-text-light/50 dark:text-text-dark/50">
        {countryPhotos.length} photos
      </p>
    </div>
    <GalleryGrid photos={countryPhotos} lang={lang} />
  </div>
</BaseLayout>
