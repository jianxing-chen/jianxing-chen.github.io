---
import { useTranslations, getLocalizedPath, type TranslationKey } from '@/i18n/ui';
import ThemeToggle from '@/components/ui/ThemeToggle.astro';
import LanguageSwitch from '@/components/ui/LanguageSwitch.astro';
import galleryData from '@/data/gallery.json';

interface Props {
  lang: string;
  isHomepage?: boolean;
}

const { lang, isHomepage = false } = Astro.props;
const t = useTranslations(lang);

// Extract unique countries from gallery for nav dropdown, sorted alphabetically
const galleryCountries = Array.from(
  new Map(galleryData.map((p) => [p.location.en, p.location])).values()
)
  .sort((a, b) => a.en.localeCompare(b.en))
  .map((loc) => ({
    label: loc[lang as 'en' | 'zh'] || loc.en,
    hash: `#country-${loc.en.toLowerCase().replace(/\s+/g, '-')}`,
  }));

const navItems: Array<{
  key: TranslationKey;
  path: string;
  label?: string;
  children?: Array<{ key?: TranslationKey; hash: string; label?: string }>;
}> = [
  { key: 'nav.home', path: '/' },
  { key: 'nav.about', path: '/about/', children: [
    { key: 'nav.about.cv', hash: '#cv' },
    { key: 'nav.about.publications', hash: '#publications' },
    { key: 'nav.about.news', hash: '#news' },
    { key: 'nav.about.contact', hash: '#contact' },
  ]},
  { key: 'nav.research', path: '/research/', children: [
    { key: 'nav.research.programs', hash: '#programs' },
    { key: 'nav.research.data_products', hash: '#data-products' },
  ]},
  { key: 'nav.blog', path: '/blog/' },
  { key: 'nav.gallery', path: '/gallery/', children: galleryCountries },
];

const currentPath = Astro.url.pathname;

function isActive(itemPath: string): boolean {
  const localizedPath = getLocalizedPath(itemPath, lang);
  if (itemPath === '/') {
    return currentPath === localizedPath || currentPath === localizedPath.replace(/\/$/, '');
  }
  return currentPath === localizedPath || currentPath.startsWith(localizedPath);
}

const activeClass = 'bg-primary-light/10 text-primary-light dark:bg-primary-dark/10 dark:text-primary-dark font-medium';
const inactiveClass = 'text-text-light dark:text-text-dark hover:text-primary-light dark:hover:text-primary-dark hover:bg-black/5 dark:hover:bg-white/5';

// ── 首页手机版信息条初始值（天气/时间/月相，与服务端 CoverSection 算法一致） ──
// 仅 isHomepage 时计算，避免非首页浪费算力
let headerTimeLabel = '';
let headerTimeText = '';
let headerHourDeg = '0';
let headerMinDeg = '0';
let headerMoonName = '';
let headerMoonLitPath = '';
let headerMoonTiltDeg = '0';
if (isHomepage) {
  const bjNowH = new Date(new Date().toLocaleString('en-US', { timeZone: 'Asia/Shanghai' }));
  const bjHH = bjNowH.getHours();
  const bjMM = bjNowH.getMinutes().toString().padStart(2, '0');
  const bjIsPM = bjHH >= 12;
  const bjH12 = bjHH % 12 || 12;
  headerTimeText = lang === 'zh'
    ? `${bjIsPM ? '下午' : '上午'}${bjH12}:${bjMM}`
    : `${bjH12}:${bjMM} ${bjIsPM ? 'PM' : 'AM'}`;
  headerTimeLabel = lang === 'zh' ? '北京' : 'Beijing';
  const bjTotalMin = bjHH * 60 + bjNowH.getMinutes();
  headerHourDeg = ((bjTotalMin / 60) * 30).toFixed(1);
  headerMinDeg = (bjNowH.getMinutes() * 6).toFixed(1);

  // 月相（共享模块 @/utils/moon.ts + SunCalc）
  const { getMoonIllumination, getMoonPosition } = await import('suncalc');
  const {
    MOON_PHASE_NAMES_ZH,
    MOON_PHASE_NAMES_EN,
    moonPhaseNameIndex,
    moonPhaseLitPath,
  } = await import('@/utils/moon');
  const moonIllum = getMoonIllumination(bjNowH);
  const moonPos = getMoonPosition(bjNowH, 39.9, 116.4);
  // 天文倾角起始值
  const hdrMoonTilt = moonIllum.angle - moonPos.parallacticAngle;
  const hdrAmplitude = Math.abs(hdrMoonTilt);
  const hdrTotalSwing = 360 - 2 * hdrAmplitude;
  const hdrHourFrac = bjNowH.getHours() + bjNowH.getMinutes() / 60;
  headerMoonTiltDeg = (hdrHourFrac <= 12
    ? hdrMoonTilt - hdrTotalSwing * (hdrHourFrac / 12)
    : hdrMoonTilt - hdrTotalSwing + hdrTotalSwing * ((hdrHourFrac - 12) / 12)).toFixed(2);
  const moonIdx = moonPhaseNameIndex(moonIllum.phase);
  headerMoonName =
    lang === 'zh'
      ? MOON_PHASE_NAMES_ZH[moonIdx]
      : MOON_PHASE_NAMES_EN[moonIdx];
  headerMoonLitPath = moonPhaseLitPath(moonIllum.fraction, moonIllum.waxing);
}
---

<header
  id="site-header"
  class:list={[
    'sticky top-0 z-50 transition-all duration-500',
    { 'header-transparent': isHomepage },
  ]}
>
  <!-- 移动端菜单栏（全宽） -->
  <div class="mobile-header-bar md:hidden flex items-center h-12 px-4">
    <button
      id="mobile-menu-btn"
      type="button"
      aria-label="Toggle menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
      class="relative w-9 h-9 flex items-center justify-center shrink-0
             text-text-light dark:text-text-dark
             hover:bg-black/5 dark:hover:bg-white/10
             rounded-lg transition-colors duration-200 cursor-pointer"
    >
      <span class="hamburger-line top-line"></span>
      <span class="hamburger-line mid-line"></span>
      <span class="hamburger-line bot-line"></span>
    </button>
    {isHomepage && (
      <div class="mobile-infobar flex-1 min-w-0 flex items-center gap-1.5 px-1.5"
           style="font-family: 'Space Grotesk', 'Inter', sans-serif; overflow: hidden;">
        <span class="flex items-center gap-0.5 shrink-0">
          <span id="cover-weather-icon-m" style="opacity:0.4">⛅</span>
          <span id="cover-weather-temp-m">--°</span>
          <span id="cover-weather-location-m" class="opacity-75 whitespace-nowrap">{headerTimeLabel}</span>
        </span>
        <span class="mobile-infobar-sep shrink-0">·</span>
        <span class="flex items-center gap-0.5 shrink-0">
          <svg class="bj-clock-icon shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
            <circle cx="12" cy="12" r="10" stroke-width="1.5"/>
            <g id="bj-hour-hand-m" class="bj-clock-hand" style="transform: rotate({headerHourDeg}deg)">
              <path d="M12 12V7" stroke-width="1.8" stroke-linecap="round"/>
            </g>
            <g id="bj-minute-hand-m" class="bj-clock-hand" style="transform: rotate({headerMinDeg}deg)">
              <path d="M12 12V3.5" stroke-width="1.1" stroke-linecap="round"/>
            </g>
          </svg>
          <span id="bj-time-text-m" class="whitespace-nowrap">{headerTimeText}</span>
          <svg id="bj-moon-svg-m" class="bj-moon-svg shrink-0" viewBox="0 0 24 24" width="0.9rem" height="0.9rem"
               role="img" aria-label={headerMoonName}>
            <title>{headerMoonName}</title>
                  <g style={`transform: rotate(${Number(headerMoonTiltDeg)}deg); transform-origin: 12px 12px;`}>
              <circle cx="12" cy="12" r="10" fill="rgba(255,255,255,0.15)" stroke="rgba(255,255,255,0.5)" stroke-width="0.6"/>
              <path id="bj-moon-lit-m" d={headerMoonLitPath} fill="rgba(255,255,255,0.95)" stroke="none"/>
            </g>
          </svg>
        </span>
      </div>
    )}
    <div class="flex items-center gap-1 ml-auto">
      <button
        type="button"
        onclick="window.__toggleSpotlight?.()"
        class="relative inline-flex items-center justify-center w-9 h-9 rounded-lg
               text-text-light dark:text-text-dark
               hover:bg-black/5 dark:hover:bg-white/10
               transition-colors duration-200 cursor-pointer"
        aria-label={lang === 'zh' ? '搜索' : 'Search'}
        title={lang === 'zh' ? '搜索 (⌘K)' : 'Search (⌘K)'}
      >
        <svg class="w-[18px] h-[18px]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" />
        </svg>
      </button>
      <LanguageSwitch lang={lang} />
      <ThemeToggle />
    </div>
  </div>

  <!-- 液态玻璃胶囊容器（仅桌面端） -->
  <div class="nav-pill-wrapper hidden md:flex justify-center relative pt-3 sm:pt-4">
    <div class="nav-pill flex items-center gap-0.5 sm:gap-1 px-1.5 sm:px-2">
    <nav aria-label="Main navigation" class="flex items-center h-10 sm:h-11">
    <!-- Desktop nav links (compact pill layout) -->
    <div class="hidden md:flex items-center gap-0.5">
      {navItems.map((item) =>
        item.children ? (
          <div class="relative group">
            <a
              href={getLocalizedPath(item.path, lang)}
              class:list={[
                'px-3 py-1.5 rounded-md text-sm transition-colors duration-200 inline-flex items-center gap-1',
                isActive(item.path) ? activeClass : inactiveClass,
              ]}
              {...(isActive(item.path) ? { 'aria-current': 'page' } : {})}
            >
              {t(item.key)}
              <svg class="w-3 h-3 opacity-50 transition-transform duration-200 group-hover:rotate-180 group-focus-within:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </a>
            <div class="desktop-dropdown-wrapper absolute left-1/2 -translate-x-1/2 top-[calc(100%+0.5rem)]
                        opacity-0 pointer-events-none translate-y-2
                        group-hover:opacity-100 group-hover:pointer-events-auto group-hover:translate-y-0
                        group-focus-within:opacity-100 group-focus-within:pointer-events-auto group-focus-within:translate-y-0
                        transition-all duration-250 ease-out
                        z-50">
              <!-- 隐形桥接层：填补菜单和下拉之间的间隙 -->
              <div class="absolute -top-2 left-0 right-0 h-2" aria-hidden="true"></div>
              <div class="desktop-dropdown-panel min-w-[180px]
                          border rounded-b-xl rounded-t-lg shadow-sm">
                <div class="desktop-dropdown-scroll max-h-[60vh] overflow-y-auto py-1.5">
                  {item.children.map((child) => (
                    <a
                      href={`${getLocalizedPath(item.path, lang)}${child.hash}`}
                            class="desktop-dropdown-link block px-4 py-2 text-sm
                             text-text-light dark:text-text-dark
                             hover:text-primary-light dark:hover:text-primary-dark
                             hover:bg-black/10 dark:hover:bg-white/10
                             transition-colors duration-150"
                    >
                      {child.label || (child.key && t(child.key))}
                    </a>
                  ))}
                </div>
                <!-- 滚动溢出提示箭头 -->
                <div class="dropdown-scroll-indicator" aria-hidden="true">
                  <svg width="16" height="10" viewBox="0 0 16 10" fill="none"><path d="M1.5 1.5l6.5 6.5 6.5-6.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </div>
              </div>
            </div>
          </div>
        ) : (
          <a
            href={getLocalizedPath(item.path, lang)}
            class:list={[
              'px-3 py-1.5 rounded-md text-sm transition-colors duration-200 inline-flex items-center',
              isActive(item.path) ? activeClass : inactiveClass,
            ]}
            {...(isActive(item.path) ? { 'aria-current': 'page' } : {})}
          >
            {item.key === 'nav.home' ? (
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-label={t('nav.home')}>
                <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 12 8.954-8.955a1.126 1.126 0 0 1 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" />
              </svg>
            ) : (
              t(item.key)
            )}
          </a>
        )
      )}
    </div>

    <!-- Desktop utilities -->
    <div class="hidden md:flex items-center gap-1 ml-1">
      <button
        type="button"
        onclick="window.__toggleSpotlight?.()"
        class="relative inline-flex items-center justify-center w-9 h-9 rounded-lg
               text-text-light dark:text-text-dark
               hover:bg-black/5 dark:hover:bg-white/10
               transition-colors duration-200 cursor-pointer"
        aria-label={lang === 'zh' ? '搜索' : 'Search'}
        title={lang === 'zh' ? '搜索 (⌘K)' : 'Search (⌘K)'}
      >
        <svg class="w-[18px] h-[18px]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" />
        </svg>
      </button>
      <LanguageSwitch lang={lang} />
      <ThemeToggle />
    </div>
  </nav>
    </div><!-- /nav-pill -->
  </div><!-- /nav-pill-wrapper -->

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="md:hidden overflow-hidden transition-[max-height] duration-300 ease-in-out max-h-0"
  >
    <div class="mobile-menu-surface px-4 pb-4 pt-2 space-y-1 border-t">
      {navItems.map((item) =>
        item.children ? (
          <div class="mobile-dropdown">
            <div class="flex items-stretch rounded-md overflow-hidden text-sm">
              <a
                href={getLocalizedPath(item.path, lang)}
                class:list={[
                  'flex-1 flex items-center pl-3 py-2.5 transition-colors duration-200',
                  isActive(item.path) ? activeClass : inactiveClass,
                ]}
              >
                {t(item.key)}
              </a>
              <button
                type="button"
                data-dropdown-toggle
                aria-label={t(item.key) + (lang === 'zh' ? '子菜单' : ' submenu')}
                class:list={[
                  'px-3 py-2.5 flex items-center justify-center transition-colors duration-200 cursor-pointer',
                  isActive(item.path) ? activeClass : inactiveClass,
                ]}
              >
                <svg class="w-3.5 h-3.5 opacity-50 transition-transform duration-200 dropdown-chevron" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                </svg>
              </button>
            </div>
            <div class="mobile-dropdown-panel overflow-hidden max-h-0 transition-all duration-200 ease-in-out">
              {item.children.map((child) => (
                <a
                  href={`${getLocalizedPath(item.path, lang)}${child.hash}`}
                  class="mobile-nav-link block pl-6 pr-3 py-2 rounded-md text-sm
                         text-text-light/70 dark:text-text-dark/70
                         hover:text-primary-light dark:hover:text-primary-dark
                         hover:bg-black/5 dark:hover:bg-white/5
                         transition-colors duration-150"
                >
                  {child.label || (child.key && t(child.key))}
                </a>
              ))}
            </div>
          </div>
        ) : (
          <a
            href={getLocalizedPath(item.path, lang)}
            class:list={[
              'mobile-nav-link block px-3 py-2.5 rounded-md text-sm transition-colors duration-200',
              isActive(item.path) ? activeClass : inactiveClass,
            ]}
            {...(isActive(item.path) ? { 'aria-current': 'page' } : {})}
          >
            {t(item.key)}
          </a>
        )
      )}
    </div>
  </div>
</header>

<style>
  .hamburger-line {
    position: absolute;
    width: 18px;
    height: 2px;
    background-color: currentColor;
    border-radius: 1px;
    transition: all 0.3s ease;
  }
  .top-line { transform: translateY(-6px); }
  .mid-line { transform: translateY(0); }
  .bot-line { transform: translateY(6px); }

  /* Open state */
  :global(.menu-open) .top-line {
    transform: translateY(0) rotate(45deg);
  }
  :global(.menu-open) .mid-line {
    opacity: 0;
  }
  :global(.menu-open) .bot-line {
    transform: translateY(0) rotate(-45deg);
  }

  /* Mobile dropdown open chevron */
  .mobile-dropdown.open .dropdown-chevron {
    transform: rotate(180deg);
  }

  /* Mobile menu: smooth scrolling on iOS */
  #mobile-menu {
    -webkit-overflow-scrolling: touch;
    overscroll-behavior: contain;
  }

  /* Desktop dropdown: prevent scroll bleed-through on touch devices (iPad) */
  .desktop-dropdown-scroll {
    overscroll-behavior: contain;
    -webkit-overflow-scrolling: touch;
  }

  .mobile-menu-surface {
    background: transparent;
    -webkit-backdrop-filter: none;
    backdrop-filter: none;
    border-top-color: transparent;
    transform: translateY(-0.35rem);
    opacity: 0;
    transition: transform 0.28s ease, opacity 0.28s ease;
  }

  #mobile-menu.menu-open-panel .mobile-menu-surface {
    transform: translateY(0);
    opacity: 1;
  }

  /* 桌面端下拉：触摸点击切换（iPad 等触摸屏优化） */
  .group.dropdown-open .desktop-dropdown-wrapper {
    opacity: 1 !important;
    pointer-events: auto !important;
    transform: translateY(0) !important;
  }
</style>

<script>
  function initMobileMenu() {
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    const menuSurface = menu?.querySelector('.mobile-menu-surface') as HTMLElement | null;
    if (!btn || !menu || !menuSurface) return;

    const btnEl = btn;
    const menuEl = menu;
    const menuSurfaceEl = menuSurface;
    const mobileBar = document.querySelector('.mobile-header-bar') as HTMLElement | null;

    function getMobileMenuMaxHeight() {
      const viewportHeight = window.visualViewport?.height ?? window.innerHeight;
      // 使用移动端 header bar 高度（桌面端 nav 在手机上 display:none 高度为 0）
      const barHeight = mobileBar?.getBoundingClientRect().height ?? 48;
      return Math.max(Math.round(viewportHeight - barHeight), 240);
    }

    // Close mobile menu helper
    function closeMenu() {
      btnEl.classList.remove('menu-open');
      btnEl.setAttribute('aria-expanded', 'false');
      menuEl.classList.remove('menu-open-panel');
      menuEl.style.maxHeight = '0';
      menuEl.style.overflowY = 'hidden';
      menuSurfaceEl.style.opacity = '0';
      menuSurfaceEl.style.transform = 'translateY(-0.35rem)';
      // 恢复滚动位置（body position:fixed 锁滚动模式）
      const scrollY = parseInt(document.body.style.top || '0', 10);
      document.documentElement.classList.remove('home-scroll-lock');
      document.body.classList.remove('home-scroll-lock');
      document.body.style.removeProperty('top');
      window.scrollTo(0, -scrollY || 0);
    }

    function openMenu() {
      // 锁定背景滚动：body position:fixed 保存滚动位置，不重置页面
      const scrollY = window.scrollY;
      document.body.style.top = `-${scrollY}px`;
      document.documentElement.classList.add('home-scroll-lock');
      document.body.classList.add('home-scroll-lock');
      menuEl.classList.add('menu-open-panel');
      menuEl.style.maxHeight = `${getMobileMenuMaxHeight()}px`;
      menuEl.style.overflowY = 'auto';
      requestAnimationFrame(() => {
        menuSurfaceEl.style.opacity = '1';
        menuSurfaceEl.style.transform = 'translateY(0)';
      });
    }

    btnEl.addEventListener('click', () => {
      const isOpen = btnEl.classList.toggle('menu-open');
      btnEl.setAttribute('aria-expanded', String(isOpen));
      if (isOpen) {
        openMenu();
      } else {
        closeMenu();
      }
    });

    window.addEventListener('resize', () => {
      if (btnEl.classList.contains('menu-open')) {
        menuEl.style.maxHeight = `${getMobileMenuMaxHeight()}px`;
      }
    });

    // Mobile dropdown toggles (accordion: close others on open)
    menu.querySelectorAll('[data-dropdown-toggle]').forEach((toggleBtn) => {
      toggleBtn.addEventListener('click', () => {
        const dropdown = toggleBtn.closest('.mobile-dropdown');
        if (!dropdown) return;
        const panel = dropdown.querySelector('.mobile-dropdown-panel') as HTMLElement;
        if (!panel) return;

        const willOpen = !dropdown.classList.contains('open');

        // Close all other dropdowns first
        menu.querySelectorAll('.mobile-dropdown.open').forEach((d) => {
          if (d !== dropdown) {
            d.classList.remove('open');
            const p = d.querySelector('.mobile-dropdown-panel') as HTMLElement;
            if (p) p.style.maxHeight = '0';
          }
        });

        // Toggle current
        if (willOpen) {
          dropdown.classList.add('open');
          panel.style.maxHeight = panel.scrollHeight + 'px';
        } else {
          dropdown.classList.remove('open');
          panel.style.maxHeight = '0';
        }
      });
    });

    // Close mobile menu when clicking a nav link
    menu.querySelectorAll('.mobile-nav-link').forEach((link) => {
      link.addEventListener('click', () => closeMenu());
    });
  }

  initMobileMenu();
  document.addEventListener('astro:after-swap', initMobileMenu);

  // ── Header transparency based on cover visibility ──
  function initHeaderTransparency() {
    const header = document.getElementById('site-header');
    if (!header) return;

    function update() {
      const coverVisible = document.documentElement.classList.contains('cover-visible');
      const el = header!;
      if (coverVisible) {
        el.classList.add('header-transparent');
      } else {
        el.classList.remove('header-transparent');
      }
    }

    // Initial check
    update();

    // Watch for class changes on <html>
    const observer = new MutationObserver((mutations) => {
      for (const m of mutations) {
        if (m.attributeName === 'class') {
          update();
          break;
        }
      }
    });
    observer.observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });
  }

  initHeaderTransparency();
  document.addEventListener('astro:after-swap', initHeaderTransparency);

  // ── 桌面端导航：触摸友好的下拉切换（仅触控设备生效） ──
  function initDesktopDropdowns() {
    const groups = document.querySelectorAll('#site-header .group');
    if (groups.length === 0) return;

    // 检测主输入设备是否为触摸屏（iPad 等），鼠标设备依赖 CSS :hover
    const touchQuery = window.matchMedia('(pointer: coarse)');

    function cleanup() {
      groups.forEach((group) => {
        const link = group.querySelector(':scope > a') as HTMLAnchorElement | null;
        if (link) link.removeEventListener('click', handleDropdownClick);
        group.querySelectorAll('.desktop-dropdown-link').forEach((child) => {
          child.removeEventListener('click', handleChildClick);
        });
      });
      document.removeEventListener('click', handleOutsideClick);
      document.removeEventListener('keydown', handleEscKey);
    }

    function handleDropdownClick(this: HTMLElement, e: MouseEvent) {
      const group = this.closest('.group');
      if (!group) return;
      const isOpen = group.classList.contains('dropdown-open');
      if (!isOpen) {
        // 首次点击：打开下拉，阻止跳转
        e.preventDefault();
        groups.forEach((g) => g !== group && g.classList.remove('dropdown-open'));
        group.classList.add('dropdown-open');
      }
      // 已打开时：允许正常跳转
    }

    function handleChildClick(this: HTMLElement) {
      const group = this.closest('.group');
      if (group) group.classList.remove('dropdown-open');
    }

    function handleOutsideClick(e: Event) {
      const target = e.target as HTMLElement;
      if (!target.closest('.group')) {
        groups.forEach((g) => g.classList.remove('dropdown-open'));
      }
    }

    function handleEscKey(e: KeyboardEvent) {
      if (e.key === 'Escape') {
        groups.forEach((g) => g.classList.remove('dropdown-open'));
      }
    }

    function setup() {
      cleanup(); // 先清理旧绑定

      if (!touchQuery.matches) {
        // 鼠标设备：移除残留的 dropdown-open，让 CSS :hover 接管
        groups.forEach((g) => g.classList.remove('dropdown-open'));
        return;
      }

      // 触控设备：拦截点击打开下拉
      groups.forEach((group) => {
        const link = group.querySelector(':scope > a') as HTMLAnchorElement | null;
        if (link) link.addEventListener('click', handleDropdownClick);
        group.querySelectorAll('.desktop-dropdown-link').forEach((child) => {
          child.addEventListener('click', handleChildClick);
        });
      });

      document.addEventListener('click', handleOutsideClick);
      document.addEventListener('keydown', handleEscKey);
    }

    setup();

    // 设备切换时重新绑定（如外接触控屏）
    touchQuery.addEventListener('change', setup);
  }

  initDesktopDropdowns();
  document.addEventListener('astro:after-swap', initDesktopDropdowns);

  // ── 桌面端下拉溢出滚动指示器 ──
  function initDropdownScrollIndicators() {
    const dropdownGroups = document.querySelectorAll('#site-header .group');

    dropdownGroups.forEach((group) => {
      const panel = group.querySelector('.desktop-dropdown-panel') as HTMLElement | null;
      const scroll = group.querySelector('.desktop-dropdown-scroll') as HTMLElement | null;
      if (!panel || !scroll) return;

      function checkOverflow() {
        const hasOverflow = scroll!.scrollHeight > scroll!.clientHeight + 1;
        panel!.classList.toggle('has-overflow', hasOverflow);
        // 初始状态下未滚动到底部
        panel!.classList.remove('scrolled-to-bottom');
      }

      function onScroll() {
        const atBottom = scroll!.scrollTop + scroll!.clientHeight >= scroll!.scrollHeight - 2;
        panel!.classList.toggle('scrolled-to-bottom', atBottom);
      }

      // 鼠标悬停 / 触摸打开时检测溢出
      group.addEventListener('mouseenter', checkOverflow);
      group.addEventListener('focusin', checkOverflow);
      scroll.addEventListener('scroll', onScroll, { passive: true });
    });
  }

  initDropdownScrollIndicators();
  document.addEventListener('astro:after-swap', initDropdownScrollIndicators);
</script>
