---
import { useTranslations } from '@/i18n/ui';
import { SITE_CONFIG } from '@/config/site';
import IconGithub from '@/components/ui/IconGithub.astro';
import IconOrcid from '@/components/ui/IconOrcid.astro';
import IconEmail from '@/components/ui/IconEmail.astro';

interface Props {
  lang: string;
  isHomepage?: boolean;
}

const { lang, isHomepage = false } = Astro.props;
const t = useTranslations(lang);
---

<div id="page-bottom">
  {isHomepage && (
  <!-- N2YO Satellite Tracker + 7Timer Astro Forecast -->
  <div class="max-w-4xl mx-auto px-4 sm:px-6 mt-10 sm:mt-20">
    <div class="flex items-baseline justify-between mb-6">
      <h2 class="text-2xl sm:text-3xl font-bold text-heading-light dark:text-heading-dark">
        {lang === 'zh' ? '实时数据' : 'Live Data'}
      </h2>
    </div>
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 lg:gap-10">
      <!-- 左：N2YO Satellite Tracker -->
      <div class="flex flex-col items-center w-full" id="n2yo-widget-container">
        <p class="text-xs text-text-light/40 dark:text-text-dark/30 mb-2 tracking-wide uppercase">
          {lang === 'zh' ? '航天器 · 实时轨道追踪' : 'Spacecraft · Live Tracking'}
        </p>
        <div class="n2yo-widget-wrapper w-full rounded-lg overflow-hidden border border-black/[0.06] dark:border-white/[0.08]" style="max-width:420px">
          <script is:inline>
            var norad_n2yo = '48274|CSS,25544|ISS,20580|HST';
            var size_n2yo = 'small';
            var allpasses_n2yo = '0';
            var map_n2yo = '4';
          </script>
          <script type="text/javascript" src="https://www.n2yo.com/js/widget-tracker.js"></script>
        </div>
      </div>
      <!-- 右：7Timer + 日出日落信息 -->
      <div class="flex flex-col items-center w-full h-full">
        <p class="text-xs text-text-light/40 dark:text-text-dark/30 mb-2 tracking-wide uppercase">
          {lang === 'zh' ? '北京 · 天文气象预报' : 'Beijing · Astro Forecast'} · 7Timer
        </p>
          <img
          src={`https://www.7timer.info/bin/astro.php?lon=116.36&lat=39.96&lang=${lang === 'zh' ? 'zh' : 'en'}&ac=0&unit=metric&tzshift=0`}
          alt={lang === 'zh' ? '天文气象预报' : 'Astro weather forecast'}
          class="forecast-thumbnail w-full"
          style="max-width:420px"
          decoding="async"
        />
        <div class="mt-2 lg:mt-auto w-full" style="max-width:420px">
        <p class="text-xs text-text-light/40 dark:text-text-dark/30 mb-1.5 tracking-wide uppercase text-center">
          {lang === 'zh' ? '日月出没' : 'Sun & Moon'}
        </p>
        <div id="beijing-sun-card"
             class="w-full rounded-lg border border-black/[0.06] dark:border-white/[0.08] bg-white/60 dark:bg-slate-800/60 backdrop-blur px-4 py-3 text-xs text-text-light/70 dark:text-text-dark/60"
             style="max-width:420px">
          <div class="grid grid-cols-2 gap-x-4 gap-y-1">
            <div class="flex justify-between col-span-2"><span class="opacity-50 font-bold">{lang === 'zh' ? '北京 39.9°N 116.4°E' : 'Beijing 39.9°N 116.4°E'}</span><span id="sun-card-date" class="tabular-nums"></span></div>
            <div class="flex justify-between col-span-2"><span>📜 {lang === 'zh' ? '农历' : 'Chinese Calendar'}</span><span id="lunar-date" class="tabular-nums">---</span></div>
            <div class="flex justify-between col-span-2"><span>🌿 {lang === 'zh' ? '节气' : 'Solar Term'}</span><span id="jieqi" class="tabular-nums">---</span></div>
            <div class="flex justify-between col-span-2"><span>🌅 {lang === 'zh' ? '日出日落' : 'Sunrise-Sunset'}</span><span class="tabular-nums"><span id="sun-rise">--:--</span> - <span id="sun-set">--:--</span></span></div>
            <div class="flex justify-between col-span-2 border-t border-black/[0.04] dark:border-white/[0.04] pt-1 mt-0.5"><span>☀️ {lang === 'zh' ? '正午 · 昼长' : 'Noon · Day'}</span><span id="sun-noon-day" class="tabular-nums">--:-- · --h --m</span></div>
            <div class="flex justify-between col-span-2 border-t border-black/[0.04] dark:border-white/[0.04] pt-1 mt-0.5"><span>🌆 {lang === 'zh' ? '民用晨光' : 'Civil dawn'}</span><span id="sun-civil" class="tabular-nums">--:-- → --:--</span></div>
            <div class="flex justify-between col-span-2"><span>🌃 {lang === 'zh' ? '航海晨光' : 'Nautical'}</span><span id="sun-naut" class="tabular-nums">--:-- → --:--</span></div>
            <div class="flex justify-between col-span-2"><span>🌌 {lang === 'zh' ? '天文晨光' : 'Astro'}</span><span id="sun-astro" class="tabular-nums">--:-- → --:--</span></div>
            <!-- 月亮信息：SunCalc 本地计算 -->
            <div class="flex justify-between col-span-2 border-t border-black/[0.04] dark:border-white/[0.04] pt-1 mt-0.5"><span>🌙 {lang === 'zh' ? '月出' : 'Moonrise'}</span><span id="moon-rise" class="tabular-nums">--:--</span></div>
            <div class="flex justify-between col-span-2"><span>🌑 {lang === 'zh' ? '月落' : 'Moonset'}</span><span id="moon-set" class="tabular-nums">--:--</span></div>
            <div class="flex justify-between col-span-2"><span>🌔 {lang === 'zh' ? '月相' : 'Phase'}</span><span><span id="moon-phase" class="tabular-nums">---</span> · <span id="moon-illum" class="tabular-nums">--</span>%</span></div>
          </div>
        </div>
        <script>
          (function() {
            var card = document.getElementById('beijing-sun-card');
            if (!card) return;
            var els = { rise: document.getElementById('sun-rise'), set: document.getElementById('sun-set'),
              noon: document.getElementById('sun-noon-day'), civil: document.getElementById('sun-civil'),
              naut: document.getElementById('sun-naut'), astro: document.getElementById('sun-astro'),
              date: document.getElementById('sun-card-date'),
              moonRise: document.getElementById('moon-rise'), moonSet: document.getElementById('moon-set'),
              moonPhase: document.getElementById('moon-phase'), moonIllum: document.getElementById('moon-illum') };
            var lat = 39.9, lng = 116.4;
            var isZh = document.documentElement.lang === 'zh';
            var cacheKey = 'bj-sun-v3-' + new Date().toDateString();
            function fmt(t) { if (!t) return '--:--'; var d = new Date(t); return d.getHours().toString().padStart(2,'0') + ':' + d.getMinutes().toString().padStart(2,'0'); }
            function fmtMoon(t) {
              if (!t) return '--:--';
              var d = new Date(t);
              var hhmm = d.getHours().toString().padStart(2,'0') + ':' + d.getMinutes().toString().padStart(2,'0');
              if (isZh) return (d.getMonth()+1) + '月' + d.getDate() + '日 ' + hhmm;
              return d.toLocaleDateString('en-US', {month:'short', day:'numeric'}) + ' ' + hhmm;
            }
            function display(d) {
              if (!d) return;
              els.rise.textContent = fmt(d.sunrise);
              els.set.textContent = fmt(d.sunset);
              var daySec = d.day_length || 0;
              els.noon.textContent = fmt(d.solar_noon) + ' · ' + Math.floor(daySec/3600) + 'h ' + Math.floor((daySec%3600)/60) + 'm';
              els.civil.textContent = fmt(d.civil_twilight_begin) + ' → ' + fmt(d.civil_twilight_end);
              els.naut.textContent = fmt(d.nautical_twilight_begin) + ' → ' + fmt(d.nautical_twilight_end);
              els.astro.textContent = fmt(d.astronomical_twilight_begin) + ' → ' + fmt(d.astronomical_twilight_end);
              var now = new Date();
              els.date.textContent = isZh
                ? now.getFullYear() + '年' + (now.getMonth() + 1) + '月' + now.getDate() + '日'
                : now.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
            }
            var cached = sessionStorage.getItem(cacheKey);
            if (cached) { display(JSON.parse(cached)); }
            fetch('https://api.sunrise-sunset.org/json?lat='+lat+'&lng='+lng+'&formatted=0')
              .then(function(r) { return r.json(); })
              .then(function(d) { if (d.status === 'OK') { sessionStorage.setItem(cacheKey, JSON.stringify(d.results)); display(d.results); } });

            // 生肖中英文映射表
            var SHENGXIAO_EN = {'鼠':'Rat','牛':'Ox','虎':'Tiger','兔':'Rabbit','龙':'Dragon','蛇':'Snake','马':'Horse','羊':'Goat','猴':'Monkey','鸡':'Rooster','狗':'Dog','猪':'Pig'};
            // 节气中英文映射表
            var JIEQI_EN = {'立春':'Beginning of Spring','雨水':'Rain Water','惊蛰':'Awakening of Insects','春分':'Spring Equinox','清明':'Pure Brightness','谷雨':'Grain Rain','立夏':'Beginning of Summer','小满':'Grain Buds','芒种':'Grain in Ear','夏至':'Summer Solstice','小暑':'Minor Heat','大暑':'Major Heat','立秋':'Beginning of Autumn','处暑':'End of Heat','白露':'White Dew','秋分':'Autumn Equinox','寒露':'Cold Dew','霜降':"Frost's Descent",'立冬':'Beginning of Winter','小雪':'Minor Snow','大雪':'Major Snow','冬至':'Winter Solstice','小寒':'Minor Cold','大寒':'Major Cold'};
            // 农历 + 节气（lunar-javascript 动态 import，独立 chunk 异步加载，零 CDN 依赖）
            import('lunar-javascript').then(function(m) {
              var Lunar = m.Lunar || (m.default && m.default.Lunar) || m.default;
              if (!Lunar) return;
              var el = document.getElementById('lunar-date');
              if (!el) return;
              var d = new Date();
              var lunar = Lunar.fromDate(d);
              if (isZh) {
                el.textContent = lunar.getYearInGanZhi() + '年' + lunar.getMonthInChinese() + '月' + lunar.getDayInChinese();
              } else {
                var mNum = lunar.getMonth();
                var isLeap = mNum < 0;
                var sx = SHENGXIAO_EN[lunar.getYearShengXiao()] || lunar.getYearShengXiao();
                el.textContent = 'Year of the ' + sx + ', ' + (isLeap ? 'Leap ' : '') + 'Month ' + Math.abs(mNum) + ', Day ' + lunar.getDay();
              }
              // 节气
              var jqEl = document.getElementById('jieqi');
              if (jqEl) {
                var next = lunar.getNextJieQi();
                if (next) {
                  var ns = next.getSolar();
                  var nextDate = new Date(ns.getYear(), ns.getMonth() - 1, ns.getDay());
                  var today = new Date(d.getFullYear(), d.getMonth(), d.getDate());
                  var days = Math.round((nextDate - today) / 86400000);
                  var jqNameZh = next.getName();
                  var jqName = isZh ? jqNameZh : (JIEQI_EN[jqNameZh] || jqNameZh);
                  jqEl.textContent = days === 0
                    ? (isZh ? '今日 ' + jqName : 'Today: ' + jqName)
                    : (isZh ? '距' + jqName + ' ' + days + '天' : jqName + ' in ' + days + 'd');
                }
              }
            });

            // 月亮数据：SunCalc 本地计算（零网络请求）
            var MP_ZH = ['朔','蛾眉月','上弦月','盈凸月','满月','亏凸月','下弦月','残月'];
            var MP_EN = ['New','Waxing Crescent','First Quarter','Waxing Gibbous','Full','Waning Gibbous','Last Quarter','Waning Crescent'];
            import('suncalc').then(function(SunCalc) {
              function updateMoon() {
                var now = new Date();
                var times = SunCalc.getMoonTimes(now, lat, lng);
                var illum = SunCalc.getMoonIllumination(now);
                var phaseIdx = Math.round(illum.phase * 8) % 8;
                if (!times.alwaysUp) {
                  els.moonRise.textContent = fmtMoon(times.rise);
                } else {
                  els.moonRise.textContent = isZh ? '不落' : 'Up all day';
                }
                if (!times.alwaysDown) {
                  els.moonSet.textContent = fmtMoon(times.set);
                } else {
                  els.moonSet.textContent = isZh ? '不升' : 'None';
                }
                els.moonPhase.textContent = isZh ? MP_ZH[phaseIdx] : MP_EN[phaseIdx];
                els.moonIllum.textContent = (illum.fraction * 100).toFixed(1);
              }
              updateMoon();
              setInterval(updateMoon, 3_600_000);
            });
          })();
        </script>
        </div>
      </div>
    </div>
  </div>
  )}

<footer class="border-t border-black/[0.06] dark:border-white/[0.06] mt-10 transition-colors duration-300">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-10">
    <div class="flex flex-col sm:flex-row items-center justify-between gap-6">
      <!-- Copyright -->
      <p class="text-sm text-text-light/50 dark:text-text-dark/40 font-medium tracking-wide">
        {t('footer.copyright')}
      </p>

      <!-- Social links -->
      <div class="flex items-center gap-4">
        <!-- GitHub -->
        <a
          href={SITE_CONFIG.social.github}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="GitHub"
          class="social-link"
        >
          <IconGithub class="w-[18px] h-[18px]" />
        </a>
        <!-- ORCID -->
        <a
          href={SITE_CONFIG.social.orcid}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="ORCID"
          class="social-link"
        >
          <IconOrcid class="w-[18px] h-[18px]" />
        </a>
        <!-- Email -->
        <a
          href={SITE_CONFIG.social.email}
          aria-label="Email"
          class="social-link"
        >
          <IconEmail class="w-[18px] h-[18px]" />
        </a>
      </div>
    </div>

    <!-- Powered by -->
    <p class="text-center text-[11px] text-text-light/25 dark:text-text-dark/25 mt-8 tracking-wider uppercase">
      {t('footer.powered_by')}
    </p>
  </div>
</footer>
</div>

<style>
  .social-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 0.5rem;
    color: #4a6a8a;
    transition: color 0.2s ease, background-color 0.2s ease, transform 0.2s ease;
  }

  :global(.dark) .social-link {
    color: #6a8aaa;
  }

  .social-link:hover {
    color: #0E3F75;
    background: rgba(14, 63, 117, 0.05);
    transform: translateY(-1px);
  }

  :global(.dark) .social-link:hover {
    color: #5B9BD5;
    background: rgba(91, 155, 213, 0.08);
  }

  .forecast-thumbnail {
    max-width: 480px;
    width: 100%;
    height: auto;
    border-radius: 0.5rem;
  }

  @media (max-width: 640px) {
    .forecast-thumbnail {
      max-width: 100%;
      width: 100%;
    }
  }
</style>
