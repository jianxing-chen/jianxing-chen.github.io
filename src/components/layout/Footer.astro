---
import { useTranslations } from '@/i18n/ui';
import { SITE_CONFIG } from '@/config/site';
import IconGithub from '@/components/ui/IconGithub.astro';
import IconOrcid from '@/components/ui/IconOrcid.astro';
import IconEmail from '@/components/ui/IconEmail.astro';

interface Props {
  lang: string;
  isHomepage?: boolean;
}

const { lang, isHomepage = false } = Astro.props;
const t = useTranslations(lang);
---

<div id="page-bottom">
  {isHomepage && (
  <!-- 7Timer Astro Forecast -->
  <div class="max-w-5xl mx-auto px-2 sm:px-6 mt-12 sm:mt-20">
    <div class="flex flex-col items-center">
      <p class="text-xs text-text-light/40 dark:text-text-dark/30 mb-2 tracking-wide uppercase">
        {lang === 'zh' ? '北京 · 天文气象预报' : 'Beijing · Astro Forecast'} · 7Timer
      </p>
      <img
        src={`https://www.7timer.info/bin/astro.php?lon=116.36&lat=39.96&lang=${lang === 'zh' ? 'zh' : 'en'}&ac=0&unit=metric&tzshift=0`}
        alt={lang === 'zh' ? '天文气象预报' : 'Astro weather forecast'}
        class="forecast-thumbnail"
        decoding="async"
      />
    </div>
  </div>
  )}

<footer class="border-t border-black/[0.06] dark:border-white/[0.06] mt-10 transition-colors duration-300">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-10">
    <div class="flex flex-col sm:flex-row items-center justify-between gap-6">
      <!-- Copyright -->
      <p class="text-sm text-text-light/50 dark:text-text-dark/40 font-medium tracking-wide">
        {t('footer.copyright')}
      </p>

      <!-- Social links -->
      <div class="flex items-center gap-4">
        <!-- GitHub -->
        <a
          href={SITE_CONFIG.social.github}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="GitHub"
          class="social-link"
        >
          <IconGithub class="w-[18px] h-[18px]" />
        </a>
        <!-- ORCID -->
        <a
          href={SITE_CONFIG.social.orcid}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="ORCID"
          class="social-link"
        >
          <IconOrcid class="w-[18px] h-[18px]" />
        </a>
        <!-- Email -->
        <a
          href={SITE_CONFIG.social.email}
          aria-label="Email"
          class="social-link"
        >
          <IconEmail class="w-[18px] h-[18px]" />
        </a>
      </div>
    </div>

    <!-- Powered by -->
    <p class="text-center text-[11px] text-text-light/25 dark:text-text-dark/25 mt-8 tracking-wider uppercase">
      {t('footer.powered_by')}
    </p>
  </div>
</footer>
</div>

<style>
  .social-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 0.5rem;
    color: #64748b;
    transition: color 0.2s ease, background-color 0.2s ease, transform 0.2s ease;
  }

  :global(.dark) .social-link {
    color: #94a3b8;
  }

  .social-link:hover {
    color: #2563EB;
    background: rgba(37, 99, 235, 0.05);
    transform: translateY(-1px);
  }

  :global(.dark) .social-link:hover {
    color: #60A5FA;
    background: rgba(96, 165, 250, 0.08);
  }

  .forecast-thumbnail {
    max-width: 480px;
    width: 100%;
    height: auto;
    border-radius: 0.5rem;
  }

  @media (max-width: 640px) {
    .forecast-thumbnail {
      max-width: 100%;
      width: 100%;
    }
  }
</style>
