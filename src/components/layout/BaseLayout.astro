---
import '@/styles/global.css';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import BackToTop from '@/components/ui/BackToTop.astro';
import SearchOverlay from '@/components/interactive/SearchOverlay.astro';
import { defaultLang } from '@/i18n/ui';
import { SITE_CONFIG } from '@/config/site';

interface Props {
  title: string;
  description?: string;
  lang?: string;
  ogImage?: string;
  isHomepage?: boolean;
}

const {
  title,
  description = 'Personal academic website built with Astro',
  lang = defaultLang,
  ogImage,
  isHomepage = false,
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
const defaultOgImage = new URL(`${import.meta.env.BASE_URL}images/og-default.svg`, Astro.site).href;
const resolvedOgImage = ogImage || defaultOgImage;
const ogLocale = lang === 'zh' ? 'zh_CN' : 'en_US';

const alternateUrl = lang === 'en'
  ? new URL('/zh' + Astro.url.pathname, Astro.site)
  : new URL(Astro.url.pathname.replace(/^\/zh/, '') || '/', Astro.site);

const socialLinks = Object.values(SITE_CONFIG.social).filter(
  (v) => v !== '#' && !v.startsWith('mailto:')
);

const umamiWebsiteId = import.meta.env.PUBLIC_UMAMI_WEBSITE_ID || '';
const umamiScriptUrl = import.meta.env.PUBLIC_UMAMI_SCRIPT_URL || 'https://cloud.umami.is/script.js';
---

<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#0E3F75" />
    <meta name="theme-color" media="(prefers-color-scheme: dark)" content="#0E3F75" />
    <link rel="icon" type="image/svg+xml" id="favicon-link" href={`${import.meta.env.BASE_URL}favicon.svg`} />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <meta name="author" content={SITE_CONFIG.author.en} />
    <link rel="canonical" href={canonicalUrl.href} />
    <link rel="alternate" hreflang={lang === 'en' ? 'zh' : 'en'} href={alternateUrl.href} />
    <link rel="alternate" hreflang="x-default" href={new URL('/', Astro.site).href} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl.href} />
    <meta property="og:image" content={resolvedOgImage} />
    <meta property="og:locale" content={ogLocale} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={resolvedOgImage} />

    <!-- Fonts -->
    <link rel="dns-prefetch" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Space+Grotesk:wght@400;500;600;700&family=Noto+Sans+SC:wght@300;400;500;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <!-- KaTeX -->
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/katex@0.16.45/dist/katex.min.css"
      integrity="sha384-UA8juhPf75SzzAMA/4fo3yOU7sBJ0om7SCD2GHq0fZqZco6tr1UCV7nUbk9J90JM"
      crossorigin="anonymous"
    />

    <!-- Theme initialization (inline to prevent FOUC) -->
    <script is:inline>
      (function() {
        const theme = localStorage.getItem('theme') ||
          (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
        if (theme === 'dark') {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>

    {/* Pagefind — preload in head; force main-thread to avoid worker issues */}
    <script type="module">
      import('/pagefind/pagefind.js').then(m => {
        m.options({ noWorker: true });
        window.__pagefind = m;
      });
    </script>

    {/* Umami Analytics */}
    {umamiWebsiteId && (
      <script is:inline defer src={umamiScriptUrl} data-website-id={umamiWebsiteId}></script>
    )}

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      "name": SITE_CONFIG.author.en,
      "url": Astro.site?.href,
      "jobTitle": SITE_CONFIG.position.en,
      "affiliation": {
        "@type": "Organization",
        "name": SITE_CONFIG.affiliation.en
      },
      ...(socialLinks.length > 0 ? { "sameAs": socialLinks } : {})
    })} />
  </head>

  <body
    data-homepage={isHomepage ? 'true' : 'false'}
    class="min-h-screen flex flex-col
           bg-background-light dark:bg-background-dark
           text-text-light dark:text-text-dark
           transition-colors duration-300
           antialiased"
    style="font-family: 'Inter', 'Noto Sans SC', sans-serif;"
  >
    <Header lang={lang} isHomepage={isHomepage} />

    {isHomepage ? (
      <main class="flex-1 w-full">
        <slot />
      </main>
    ) : (
      <main class="flex-1 w-full max-w-4xl mx-auto px-4 sm:px-6 py-8 sm:py-12">
        <slot />
      </main>
    )}

    <Footer lang={lang} isHomepage={isHomepage} />

    <BackToTop />
    <SearchOverlay lang={lang} />

    <!-- Scroll reveal observer -->
    <script is:inline>
      (function() {
        const observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              observer.unobserve(entry.target);
            }
          });
        }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });

        function observeRevealElements() {
          document.querySelectorAll('.reveal-on-scroll, .reveal-stagger').forEach((el) => {
            observer.observe(el);
          });
        }

        observeRevealElements();
        document.addEventListener('astro:after-swap', observeRevealElements);
      })();
    </script>

    <!-- Dynamic moon favicon: is:inline 零依赖，全站可靠 -->
    <script is:inline>
      (function updateMoonFavicon() {
        var favicon = document.getElementById('favicon-link');
        if (!favicon) return;

        // path 算法与 CoverSection 完全一致
        function moonLitPath(fraction, waxing, r) {
          r = r || 10;
          var rx = Math.max(Math.abs(r * (1 - 2 * fraction)), 0.000001);
          var contourSweep = waxing ? 0 : 1;
          var termSweep = waxing
            ? (fraction < 0.5 ? 1 : 0)
            : (fraction < 0.5 ? 0 : 1);
          return 'M 12 ' + (12 - r) + ' A ' + r + ' ' + r + ' 0 0 ' + contourSweep +
            ' 12 ' + (12 + r) + ' A ' + rx + ' ' + r + ' 0 0 ' + termSweep + ' 12 ' + (12 - r) + ' Z';
        }

        function update() {
          var avgSynodic = 29.530588853;
          var jd = Date.now() / 86400000 + 2440587.5;
          var daysSinceJ2000 = jd - 2451549.5;
          // 动态最近新月（JDE = 2451550.1 + N * 29.530588853，Meeus ch.49）
          var lunations = Math.round((daysSinceJ2000 - 0.1) / avgSynodic);
          var lastNewMoonJD = 2451550.1 + lunations * avgSynodic;
          var phase = (jd - lastNewMoonJD) / avgSynodic;
          var fraction = (1 - Math.cos(phase * 2 * Math.PI)) / 2;
          var waxing = phase < 0.5;
          var path = moonLitPath(fraction, waxing);
          var svg = '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">' +
            '<circle cx="12" cy="12" r="12" fill="#0E3F75"/>' +
            '<g transform="matrix(-1,0,0,1,24,0)">' +
            '<path d="' + path + '" fill="white" stroke="none"/>' +
            '</g></svg>';
          favicon.href = 'data:image/svg+xml,' + encodeURIComponent(svg);
        }

        update();
        setInterval(update, 3600000);
      })();
    </script>
  </body>
</html>
