    line-height: 1.4;
  }
  .sbc {
    color: var(--color-muted-light);
    font-weight: 500;
  }
  .dark .sbc { color: var(--color-muted-dark); }
  .sbc-sep {
    color: var(--color-muted-light);
    opacity: 0.5;
    margin: 0 2px;
    font-weight: 300;
  }
  .dark .sbc-sep { color: var(--color-muted-dark); }
  .sbc-sub {
    color: var(--color-primary-light);
    font-weight: 400;
    opacity: 0.7;
  }
  .dark .sbc-sub { color: var(--color-primary-dark); }

  .s-meta {
    font-size: 11px;
    color: var(--color-muted-light);
    opacity: 0.6;
    margin-top: 1px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .dark .s-meta { color: var(--color-muted-dark); }

  .s-snippet {
    font-size: 11px;
    line-height: 1.45;
    color: var(--color-muted-light);
    opacity: 0.75;
    margin-top: 3px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .dark .s-snippet { color: var(--color-muted-dark); }

  /* ── 搜索高亮 ── */
  .shl {
    background-color: rgba(251, 191, 36, 0.3);
    color: inherit;
    border-radius: 2px;
    padding: 0 1px;
  }
  .dark .shl { background-color: rgba(251, 191, 36, 0.35); }
</style>
