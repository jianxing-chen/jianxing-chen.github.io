---
/**
 * CoverSection.astro — 主页固定封面背景层
 *
 * v2 变更：
 * - 封面图层改为 position: fixed，不再随页面滚动
 * - 移除 Hero 插槽（Hero 在 index.astro 的滚动内容层中统一渲染）
 * - 新增翻页动画：JS 检测 wheel/touch → spring easing scrollTo 到内容区
 * - 翻页后封面层淡出隐藏，滚回顶部后重新显示
 */

import { getCoverImage, getCoverImageMobile } from '@/utils/cloudinary';
import { getGalleryPhotoDetailPath, type GalleryPhoto } from '@/utils/gallery';
import { SITE_CONFIG } from '@/config/site';

interface Props {
  photos: GalleryPhoto[];
  lang: string;
}

const { photos, lang } = Astro.props;

const fixedCoverIds = [...SITE_CONFIG.coverPhotoIds];

const fixedCoverPhotos = fixedCoverIds
  .map((id) => photos.find((p) => p.cloudinaryId === id))
  .filter((p): p is GalleryPhoto => Boolean(p));

const selectedCoverPhotos = fixedCoverPhotos.length === fixedCoverIds.length
  ? fixedCoverPhotos
  : photos.slice(0, 5);

const coverPhotos = selectedCoverPhotos.map((p) => ({
  id: p.id,
  desktop: getCoverImage(p.cloudinaryId),
  mobile: getCoverImageMobile(p.cloudinaryId),
  href: getGalleryPhotoDetailPath(p, lang),
  title: p.title,
  location: p.location,
  region: p.region,
}));

const startIdx = coverPhotos.length > 0 ? Math.floor(Math.random() * coverPhotos.length) : 0;

// 服务端预渲染北京时间，避免页面加载后 JS 才显示造成延迟
const bjNow = new Date(new Date().toLocaleString('en-US', { timeZone: 'Asia/Shanghai' }));
const bjH = bjNow.getHours();
const bjM = bjNow.getMinutes().toString().padStart(2, '0');
const bjIsPM = bjH >= 12;
const bjHour12 = bjH % 12 || 12;
const initialTimeText = lang === 'zh'
  ? `${bjIsPM ? '下午' : '上午'}${bjHour12}:${bjM}`
  : `${bjHour12}:${bjM} ${bjIsPM ? 'PM' : 'AM'}`;
const initialTimeLabel = lang === 'zh' ? '北京' : 'Beijing';

// 时钟指针初始旋转角度
const bjTotalMin = bjH * 60 + bjNow.getMinutes();
const initialHourDeg = ((bjTotalMin / 60) * 30).toFixed(1);  // 时针: (时*60+分)/720*360
const initialMinDeg = (bjNow.getMinutes() * 6).toFixed(1);     // 分针: 分*6
---

{coverPhotos.length === 0 ? (
  <div id="cover-bg-layer" class="cover-bg-layer cover-hidden"></div>
) : (
  <>
  <!-- ═══ 固定封面背景层 ═══ -->
  <div id="cover-bg-layer" class="cover-bg-layer">
    <script type="application/json" id="cover-data" set:html={JSON.stringify({ photos: coverPhotos, startIndex: startIdx, lang })}></script>

    <img id="cover-img-current" class="cover-bg-img" src={coverPhotos[startIdx]!.desktop} alt="" role="presentation" style="opacity:1" />
    <img id="cover-img-next" class="cover-bg-img" src="" alt="" role="presentation" style="opacity:0" />
    <div class="cover-bg-overlay"></div>
  </div>

<!-- ═══ 封面 UI 层（提出 cover-bg-layer 以逃脱 z-index 牢笼） ═══ -->
<div id="cover-credit" class="cover-credit"></div>

<div
  id="cover-pagination"
  class="cover-pagination"
  data-lang={lang}
  role="tablist"
  aria-label={lang === 'zh' ? '封面轮播分页' : 'Cover carousel pagination'}
></div>

<!-- 北京时间（封面右上角，跟随封面层消失） -->
<div id="cover-beijing-time" class="cover-beijing-time"
     style="font-family: 'Space Grotesk', 'Inter', sans-serif;">
  <svg
    class="bj-clock-icon"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    aria-hidden="true"
  >
    <circle cx="12" cy="12" r="10" stroke-width="1.5"/>
    <g id="bj-hour-hand" class="bj-clock-hand" style="transform: rotate({initialHourDeg}deg)">
      <path d="M12 12V7" stroke-width="1.8" stroke-linecap="round"/>
    </g>
    <g id="bj-minute-hand" class="bj-clock-hand" style="transform: rotate({initialMinDeg}deg)">
      <path d="M12 12V3.5" stroke-width="1.1" stroke-linecap="round"/>
    </g>
  </svg>
  <span id="bj-time-text">{initialTimeText}</span>
  <span id="bj-time-label" style="opacity: 0.75;">{initialTimeLabel}</span>
</div>

<button class="cover-scroll-indicator" aria-label={lang === 'zh' ? '向下翻页' : 'Scroll down'}>
  <svg class="cover-scroll-indicator-icon w-7 h-7 text-white drop-shadow-md" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
    <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
  </svg>
</button>

<!-- 返回封面按钮（移动端正文态） -->
<button id="back-to-cover-btn" class="back-to-cover-btn"
  aria-label={lang === 'zh' ? '返回图库' : 'Back to gallery'}>
  <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
    <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 15.75l7.5-7.5 7.5 7.5" />
  </svg>
</button>

<script>
  // ── 北京时间 — 独立运行，最早执行，不依赖封面初始化 ──
  (function initBeijingTime() {
    const timeEl = document.getElementById('bj-time-text');
    const labelEl = document.getElementById('bj-time-label');
    const hourHandEl = document.getElementById('bj-hour-hand');
    const minuteHandEl = document.getElementById('bj-minute-hand');
    if (!timeEl || !labelEl) return;

    // 读取语言：优先 pagination 上的 data-lang，fallback 到 html lang
    const pagination = document.getElementById('cover-pagination');
    const lang = pagination?.dataset.lang || document.documentElement.lang || 'en';
    const isZh = lang === 'zh';

    function update() {
      if (!timeEl || !labelEl) return;
      const now = new Date();
      const bj = new Date(now.toLocaleString('en-US', { timeZone: 'Asia/Shanghai' }));
      let h = bj.getHours();
      const m = bj.getMinutes();
      const mm = m.toString().padStart(2, '0');
      const ampm = h >= 12 ? 'PM' : 'AM';
      h = h % 12 || 12;

      const newText = isZh
        ? `${ampm === 'PM' ? '下午' : '上午'}${h}:${mm}`
        : `${h}:${mm} ${ampm}`;
      if (timeEl.textContent !== newText) {
        timeEl.textContent = newText;
        labelEl.textContent = isZh ? '北京' : 'Beijing';
      }

      // 指针每分钟更新（仅含分精度）
      const totalMin = bj.getHours() * 60 + m;
      if (hourHandEl) {
        hourHandEl.style.transform = `rotate(${(totalMin / 60) * 30}deg)`;
      }
      if (minuteHandEl) {
        minuteHandEl.style.transform = `rotate(${m * 6}deg)`;
      }
    }

    update();
    // 对齐到下一完整分钟，之后每分钟更新一次
    const now = new Date();
    const msToNextMinute = (60 - now.getSeconds()) * 1000 - now.getMilliseconds();
    setTimeout(() => { update(); setInterval(update, 60_000); }, msToNextMinute);
  })();

  // 上一次 init 创建的 AbortController：新 init 或页面切换前 abort，
  // 一次性移除全部 document/window 监听器，避免 View Transitions 切换首页时叠加泄漏。
  let coverAbortController: AbortController | null = null;
  function disposeCover() {
    coverAbortController?.abort();
    coverAbortController = null;
  }
  document.addEventListener('astro:before-swap', disposeCover, { once: true });

  function initCoverSection() {
    // 先清理上一轮（防御性：理论上 before-swap 已处理）
    disposeCover();

    const layer = document.getElementById('cover-bg-layer');
    if (!layer || layer.dataset.coverInit) return;
    layer.dataset.coverInit = 'true';

    // 本轮所有全局监听器共用此 signal，abort 时统一移除
    const ac = new AbortController();
    coverAbortController = ac;
    const listenerOpts = { signal: ac.signal } as AddEventListenerOptions;

    const imgCurrent = document.getElementById('cover-img-current') as HTMLImageElement | null;
    const imgNext = document.getElementById('cover-img-next') as HTMLImageElement | null;
    const pagination = document.getElementById('cover-pagination');
    const backToCoverBtn = document.getElementById('back-to-cover-btn');

    if (!imgCurrent || !imgNext) return;

    const coverDataEl = document.getElementById('cover-data');
    if (!coverDataEl) return;
    const coverData = JSON.parse(coverDataEl.textContent || '{}');

    type CoverPhoto = { id: string; desktop: string; mobile: string; href: string; title: { en: string; zh?: string }; location: { en: string; zh?: string }; region: { en: string; zh?: string } };
    const coverPhotos: CoverPhoto[] = coverData.photos || [];
    const startIdx: number = coverData.startIndex ?? 0;
    const coverLang: string = coverData.lang || 'en';
    if (coverPhotos.length === 0) return;
    let currentIndex = startIdx;

    let activeImg = imgCurrent;
    let hiddenImg = imgNext;
    const warmedImageSources = new Set<string>();
    const imageErrorCount = new Map<string, number>();

    function createPagination() {
      if (!pagination) return;
      const labels = {
        tab: coverLang === 'zh' ? '跳转到第' : 'Go to photo',
        activeSuffix: coverLang === 'zh' ? '（当前）' : '(current)',
      };

      pagination.innerHTML = coverPhotos
        .map((_, idx) => {
          const active = idx === currentIndex;
          const text = `${labels.tab} ${idx + 1}`;
          return `<button type="button" class="cover-page-dot${active ? ' is-active' : ''}" data-cover-dot="${idx}" role="tab" aria-label="${text}${active ? labels.activeSuffix : ''}" aria-selected="${active ? 'true' : 'false'}"></button>`;
        })
        .join('');

      pagination.querySelectorAll<HTMLButtonElement>('[data-cover-dot]').forEach((dot) => {
        dot.addEventListener('click', () => {
          const idx = Number(dot.dataset.coverDot);
          if (!Number.isNaN(idx)) showPhoto(idx);
        });
      });
    }

    function updatePagination(index: number) {
      if (!pagination) return;
      pagination.querySelectorAll<HTMLButtonElement>('[data-cover-dot]').forEach((dot) => {
        const dotIndex = Number(dot.dataset.coverDot);
        const isActive = dotIndex === index;
        dot.classList.toggle('is-active', isActive);
        dot.setAttribute('aria-selected', isActive ? 'true' : 'false');
      });
    }

    function isMobile(): boolean { return window.innerWidth < 768; }
    function getSrc(p: CoverPhoto): string { return isMobile() ? p.mobile : p.desktop; }

    function updateCredit(index: number) {
      const credit = document.getElementById('cover-credit');
      if (!credit || index < 0 || index >= coverPhotos.length) return;
      const photo = coverPhotos[index];
      const locName = photo.location?.[coverLang as 'en' | 'zh'] || photo.location?.en || '';
      const regionName = photo.region?.[coverLang as 'en' | 'zh'] || photo.region?.en || '';
      const titleName = photo.title?.[coverLang as 'en' | 'zh'] || photo.title?.en || '';
      const displayLoc = locName && regionName ? `${locName}, ${regionName}` : (locName || regionName);
      const locLink = displayLoc && photo.href
        ? `<a href="${photo.href}" class="cover-credit-link">${displayLoc}</a>`
        : displayLoc;
      credit.innerHTML = isMobile()
        ? (locLink || '')
        : (locLink && titleName ? `${locLink} · ${titleName}` : (titleName || locLink));
    }

    function showPhoto(index: number) {
      if (index === currentIndex || coverPhotos.length === 0) return;
      currentIndex = index;
      const src = getSrc(coverPhotos[index]);
      hiddenImg.onload = () => { hiddenImg.style.opacity = '1'; activeImg.style.opacity = '0'; [activeImg, hiddenImg] = [hiddenImg, activeImg]; };
      hiddenImg.onerror = () => { hiddenImg.style.opacity = '1'; activeImg.style.opacity = '0'; [activeImg, hiddenImg] = [hiddenImg, activeImg]; };
      hiddenImg.src = src;
      updateCredit(index);
      updatePagination(index);
      preloadAdjacent(index);
    }

    function nextPhoto() {
      if (coverPhotos.length <= 1) return;
      const nextIndex = (currentIndex + 1) % coverPhotos.length;
      showPhoto(nextIndex);
    }

    function prevPhoto() {
      if (coverPhotos.length <= 1) return;
      const prevIndex = (currentIndex - 1 + coverPhotos.length) % coverPhotos.length;
      showPhoto(prevIndex);
    }

    let autoRotateTimer: ReturnType<typeof setInterval> | null = null;

    function startAutoRotate() {
      stopAutoRotate();
      if (coverPhotos.length <= 1) return;
      autoRotateTimer = setInterval(() => {
        if (currentState === 'cover') nextPhoto();
      }, 18000);
    }

    function stopAutoRotate() {
      if (autoRotateTimer) {
        clearInterval(autoRotateTimer);
        autoRotateTimer = null;
      }
    }

    function preloadAdjacent(index: number) {
      if (coverPhotos.length === 0) return;
      const next = (index + 1) % coverPhotos.length;
      const prev = (index - 1 + coverPhotos.length) % coverPhotos.length;
      [next, prev].forEach((i) => {
        if (i !== index) {
          const src = getSrc(coverPhotos[i]);
          if (warmedImageSources.has(src)) return;
          const errCount = imageErrorCount.get(src) || 0;
          if (errCount >= 3) return; // give up after 3 consecutive failures
          warmedImageSources.add(src);
          const preloadImage = new Image();
          preloadImage.decoding = 'async';
          preloadImage.onerror = () => {
            warmedImageSources.delete(src);
            imageErrorCount.set(src, (imageErrorCount.get(src) || 0) + 1);
          };
          preloadImage.src = src;
        }
      });
    }

    document.addEventListener('keydown', (e) => {
      if (e.target instanceof HTMLInputElement || e.target instanceof HTMLTextAreaElement || (e.target as HTMLElement)?.isContentEditable) return;
      if (e.key === 'ArrowLeft') prevPhoto();
      if (e.key === 'ArrowRight') nextPhoto();
    }, listenerOpts);
    createPagination();
    updatePagination(currentIndex);

    const pageContent = document.getElementById('page-content');
    const hero = document.getElementById('hero-unified');
    const scrollIndicator = document.querySelector('.cover-scroll-indicator');
    if (!pageContent) return;

    const coverLayer = layer;
    const contentLayer = pageContent;

    let currentState: 'cover' | 'content' | 'transitioning-to-content' | 'transitioning-to-cover' = 'cover';
    let transitionTimer: ReturnType<typeof setTimeout> | null = null;
    const transitionDuration = 800;

    function setScrollLocked(locked: boolean) {
      if (locked) {
        const scrollY = window.scrollY;
        document.body.style.top = `-${scrollY}px`;
      } else {
        const scrollY = parseInt(document.body.style.top || '0', 10);
        document.body.style.removeProperty('top');
        window.scrollTo(0, -scrollY || 0);
      }
      document.documentElement.classList.toggle('home-scroll-lock', locked);
      document.body.classList.toggle('home-scroll-lock', locked);
    }

    function setCoverVisible(visible: boolean) {
      document.documentElement.classList.toggle('cover-visible', visible);
    }

    function setHeroTone(isContent: boolean) {
      if (!hero) return;
      hero.classList.toggle('hero-text-cover', !isContent);
      hero.classList.toggle('hero-text-themed', isContent);
    }

    function clearTransitionTimer() {
      if (transitionTimer) {
        clearTimeout(transitionTimer);
        transitionTimer = null;
      }
    }


    function enterCoverState() {
      clearTransitionTimer();
      // ── 恢复 credit 文字可见 ──
      const creditEl = document.getElementById('cover-credit');
      if (creditEl) creditEl.classList.remove('cover-credit-fading');
      currentState = 'cover';
      contentLayer.classList.remove('state-content', 'is-animating');
      contentLayer.classList.add('state-cover');
      coverLayer.classList.remove('cover-hidden');
      setCoverVisible(true);
      setHeroTone(false);
      window.scrollTo({ top: 0, behavior: 'auto' });
      setScrollLocked(true);
      startAutoRotate();
      if (backToCoverBtn) backToCoverBtn.style.display = 'none';
    }

    function enterContentState() {
      clearTransitionTimer();
      currentState = 'content';
      contentLayer.classList.remove('state-cover', 'is-animating');
      contentLayer.classList.add('state-content');
      coverLayer.classList.add('cover-hidden');
      setCoverVisible(false);
      setHeroTone(true);
      window.scrollTo({ top: 0, behavior: 'auto' });
      setScrollLocked(false);
      if (backToCoverBtn) backToCoverBtn.style.display = 'flex';
    }

    function transitionToContent() {
      if (currentState !== 'cover') return;
      stopAutoRotate();
      clearTransitionTimer();
      // ── 在滑动手势/按键瞬间就开始渐隐 credit 文字 ──
      const creditEl = document.getElementById('cover-credit');
      if (creditEl) creditEl.classList.add('cover-credit-fading');
      // ── 北京时间同步渐隐 ──
      const timeEl = document.getElementById('cover-beijing-time');
      if (timeEl) timeEl.classList.add('cover-time-fading');
      // ── 菜单栏文字与 hero 同步变色，不再等 800ms 动画 ──
      const header = document.getElementById('site-header');
      if (header) header.classList.remove('header-transparent');
      currentState = 'transitioning-to-content';
      setScrollLocked(true);
      setCoverVisible(true);
      setHeroTone(true);
      coverLayer.classList.add('cover-hidden');
      contentLayer.classList.add('is-animating', 'state-content');
      contentLayer.classList.remove('state-cover');

      transitionTimer = setTimeout(() => {
        enterContentState();
      }, transitionDuration);
    }

    function transitionToCover() {
      if (currentState !== 'content' || window.scrollY > 30) return;
      clearTransitionTimer();
      // ── credit 文字与菜单栏颜色同步渐现，不再等 800ms 动画 ──
      const creditEl = document.getElementById('cover-credit');
      if (creditEl) creditEl.classList.remove('cover-credit-fading');
      const timeEl = document.getElementById('cover-beijing-time');
      if (timeEl) timeEl.classList.remove('cover-time-fading');
      const header = document.getElementById('site-header');
      if (header) header.classList.add('header-transparent');
      currentState = 'transitioning-to-cover';

      // 先标记 cover 可见（隐藏 footer），再滚回顶部
      setCoverVisible(true);
      window.scrollTo({ top: 0, behavior: 'auto' });
      requestAnimationFrame(() => {
        setScrollLocked(true);
        coverLayer.classList.remove('cover-hidden');
        setHeroTone(false);
        contentLayer.classList.add('is-animating', 'state-cover');
        contentLayer.classList.remove('state-content');

        transitionTimer = setTimeout(() => {
          enterCoverState();
        }, transitionDuration);
      });
    }

    enterCoverState();

    // ── 检查是否被模态浮层（搜索/移动菜单/桌面端下拉）占用 ──
    function isModalOpen(): boolean {
      const spotlight = document.getElementById('spotlight-overlay');
      if (spotlight && spotlight.getAttribute('aria-hidden') === 'false') return true;
      const menuBtn = document.getElementById('mobile-menu-btn');
      if (menuBtn && menuBtn.classList.contains('menu-open')) return true;
      // 桌面端下拉菜单打开时（iPad 等触控设备）
      if (document.querySelector('.group.dropdown-open')) return true;
      return false;
    }

    window.addEventListener('wheel', (e) => {
      // 当搜索浮层或移动菜单打开时，不响应封面翻页
      if (isModalOpen()) return;
      // 忽略下拉菜单内的滚动
      if ((e.target as HTMLElement).closest('.desktop-dropdown-panel')) return;
      if (currentState === 'cover' && e.deltaY > 0) {
        e.preventDefault();
        transitionToContent();
      } else if (currentState === 'content' && e.deltaY < 0 && window.scrollY <= 30) {
        e.preventDefault();
        transitionToCover();
      } else if (currentState.startsWith('transitioning')) {
        e.preventDefault();
      }
    }, { passive: false, ...listenerOpts });

    scrollIndicator?.addEventListener('click', () => {
      if (currentState === 'cover' && !isModalOpen()) transitionToContent();
    });

    backToCoverBtn?.addEventListener('click', () => {
      if (currentState === 'content') {
        window.scrollTo({ top: 0, behavior: 'smooth' });
        setTimeout(() => transitionToCover(), 120);
      }
    });

    let gestureStartX = 0;
    let gestureStartY = 0;
    let gestureActive = false;
    document.addEventListener('touchstart', (e) => {
      gestureActive = false;
      if (isModalOpen()) return;
      const target = e.target as HTMLElement;
      // 跳过桌面端下拉菜单、移动端菜单、header 内的触摸，避免手势穿透
      if (target.closest('.desktop-dropdown-wrapper') || target.closest('#mobile-menu') || target.closest('.mobile-header-bar')) return;
      gestureActive = true;
      gestureStartX = e.touches[0].clientX;
      gestureStartY = e.touches[0].clientY;
    }, { passive: true, ...listenerOpts });

    document.addEventListener('touchend', (e) => {
      if (!gestureActive) return;
      gestureActive = false;
      if (isModalOpen()) return;
      const dx = e.changedTouches[0].clientX - gestureStartX;
      const dy = e.changedTouches[0].clientY - gestureStartY;

      if (Math.abs(dx) > Math.abs(dy) && Math.abs(dx) > 50) {
        if (dx < 0) nextPhoto();
        else prevPhoto();
        return;
      }

      if (Math.abs(dy) > Math.abs(dx) && Math.abs(dy) > 60) {
        if (currentState === 'cover' && dy < 0) {
          transitionToContent();
        } else if (currentState === 'content' && dy > 0 && window.scrollY <= 30) {
          transitionToCover();
        }
      }
    }, listenerOpts);

    // 窗口 resize 切换图片分辨率
    let resizeTimer: ReturnType<typeof setTimeout>;
    window.addEventListener('resize', () => {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(() => {
        if (coverPhotos.length === 0) return;
        const src = getSrc(coverPhotos[currentIndex]);
        if (activeImg.src !== src) activeImg.src = src;
      }, 300);
    }, listenerOpts);

    // AbortController 触发时（页面切换或重新 init）：清理定时器，确保轮播/过渡逻辑不再继续运行。
    ac.signal.addEventListener('abort', () => {
      stopAutoRotate();
      clearTransitionTimer();
      clearTimeout(resizeTimer);
    });

    updateCredit(currentIndex);
    preloadAdjacent(currentIndex);
  }

  initCoverSection();
  document.addEventListener('astro:after-swap', initCoverSection);
</script>
  </>
)}
