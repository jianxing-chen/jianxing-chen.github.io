---
interface Props {
  title: string;
  description: string;
  cover?: string;
  status: string;
  tags: string[];
  href: string;
  statusLabel?: string;
}

const { title, description, cover, status, tags, href, statusLabel } = Astro.props;

const isOngoing = status === 'ongoing';
---

<a href={href} class="project-card group block rounded-xl overflow-hidden
  bg-white dark:bg-white/[0.03]
  border border-slate-200/70 dark:border-white/[0.05]
  shadow-sm
  hover:shadow-md hover:border-primary-light/25 dark:hover:border-primary-dark/20
  hover:-translate-y-0.5
  transition-all duration-300 ease-out">

  {/* Cover image */}
  <div class="aspect-video overflow-hidden bg-slate-50 dark:bg-white/[0.02]">
    {cover ? (
      <img
        src={cover}
        alt={title}
        class="w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-500 ease-out"
        loading="lazy"
      />
    ) : (
      <div class="w-full h-full flex items-center justify-center text-slate-300 dark:text-slate-600">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-12 h-12" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 3.104v5.714a2.25 2.25 0 0 1-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.3 24.3 0 0 1 4.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0 1 12 15a9.065 9.065 0 0 0-6.23.693L5 14.5m14.8.8 1.402 1.402c1.232 1.232.65 3.318-1.067 3.611A48.309 48.309 0 0 1 12 21c-2.773 0-5.491-.235-8.135-.687-1.718-.293-2.3-2.379-1.067-3.61L5 14.5" />
        </svg>
      </div>
    )}
  </div>

  {/* Content */}
  <div class="p-5">
    {/* Status badge */}
    <div class="mb-3">
      <span class:list={[
        'inline-flex items-center px-2 py-0.5 rounded-full text-[11px] font-medium',
        isOngoing
          ? 'bg-emerald-50 text-emerald-700 dark:bg-emerald-900/20 dark:text-emerald-400'
          : 'bg-slate-100 text-slate-500 dark:bg-white/[0.05] dark:text-slate-400',
      ]}>
        <span class:list={[
          'w-1.5 h-1.5 rounded-full mr-1.5',
          isOngoing ? 'bg-emerald-500' : 'bg-slate-400 dark:bg-slate-500',
        ]}></span>
        {statusLabel || (isOngoing ? 'Ongoing' : 'Completed')}
      </span>
    </div>

    {/* Title */}
    <h3 class="text-base font-semibold text-heading-light dark:text-heading-dark mb-2
               group-hover:text-primary-light dark:group-hover:text-primary-dark
               transition-colors duration-200 line-clamp-2"
        style="font-family: 'Space Grotesk', 'Inter', sans-serif;">
      {title}
    </h3>

    <!-- Description -->
    <p class="text-sm text-text-light/60 dark:text-text-dark/50 mb-4 line-clamp-2 leading-relaxed">
      {description}
    </p>

    <!-- Tags -->
    {tags.length > 0 && (
      <div class="flex flex-wrap gap-1.5">
        {tags.map((tag) => (
          <span class="inline-block px-2 py-0.5 text-[11px] rounded-md font-medium
                        bg-primary-light/[0.06] text-primary-light/80
                        dark:bg-primary-dark/[0.08] dark:text-primary-dark/80
                        border border-primary-light/10 dark:border-primary-dark/15">
            {tag}
          </span>
        ))}
      </div>
    )}
  </div>
</a>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
