---
/**
 * 图库首页总览组件
 * 功能：渲染 gallery 首页的国家时间轴布局。桌面端左列为国家名 + More 链接，中间伪元素时间轴（线穿点），
 *       右侧为 JS 贪心算法驱动的 flex masonry 瀑布流。移动端降级为 CSS columns 分块。
 * 输入：照片数组、语言代码、每国摘录上限。
 * 输出：带自定义 PhotoViewer 的首页图片总览。
 * 用法示例：<GalleryOverview photos={photos} lang="zh" previewLimit={10} />
 */

import { getGalleryFullSize } from '@/utils/cloudinary';
import { buildGalleryCountries, getGalleryCountryPath, type GalleryPhoto } from '@/utils/gallery';
import { computeGroupedMasonryLayout } from '@/utils/masonry';
import PhotoViewer from '@/components/interactive/PhotoViewer.astro';
import GalleryCard from '@/components/ui/GalleryCard.astro';

interface Props {
  photos: GalleryPhoto[];
  lang: string;
  previewLimit?: number;
}

const { photos, lang, previewLimit = 10 } = Astro.props;
const countries = buildGalleryCountries(photos, lang, previewLimit);
const moreLabel = lang === 'zh' ? 'More' : 'More';
const masonryColumns = 3;

// 预计算每个国家的 masonry 布局 + 收集所有预览照片用于 viewer
const allPreviewPhotos: GalleryPhoto[] = [];
const countryLayouts = countries.map((country) => {
  allPreviewPhotos.push(...country.previewPhotos);
  return {
    ...country,
    columns: computeGroupedMasonryLayout(country.previewPhotos, masonryColumns),
  };
});

// 序列化照片数据供 PhotoViewer 使用
const viewerPhotos = allPreviewPhotos.map((p) => ({
  id: p.id,
  src: getGalleryFullSize(p.cloudinaryId),
  width: p.width,
  height: p.height,
  title: p.title[lang as keyof typeof p.title] || p.title.en,
  description: p.description[lang as keyof typeof p.description] || p.description.en,
  location: p.location[lang as keyof typeof p.location] || p.location.en,
  region: p.region[lang as keyof typeof p.region] || p.region.en,
  tags: p.tags,
}));
---

<div id="gallery-overview" class="gallery-overview">
  {countryLayouts.map((country) => (
    <section id={country.anchorId} class="gallery-overview__row" style="scroll-margin-top: 5rem;">
      <!-- 左列：国家名 + More 链接 -->
      <div class="gallery-overview__meta">
        <p class="gallery-overview__country">{country.display}</p>
        <a href={getGalleryCountryPath(country.countrySlug, lang)} class="gallery-overview__more">
          <span>{moreLabel}</span>
          <svg class="more-arrow" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 12h12m0 0-5-5m5 5-5 5" />
          </svg>
        </a>
      </div>

      <!-- 右列：flex masonry 瀑布流（桌面端）；移动端回退 CSS columns -->
      <div class="gallery-overview__content">
        <!-- 桌面端：flex 多列布局 -->
        <div class="gallery-masonry gallery-masonry--desktop">
          {country.columns.map((col) => (
            <div class="gallery-masonry__column">
              {col.items.map((photo) => (
                <GalleryCard photo={photo} lang={lang} showId />
              ))}
            </div>
          ))}
        </div>

        <!-- 移动端：CSS columns 回退（隐藏于桌面端） -->
        <div class="gallery-masonry gallery-masonry--mobile">
          {country.previewPhotos.map((photo) => (
            <GalleryCard photo={photo} lang={lang} />
          ))}
        </div>
      </div>
    </section>
  ))}
</div>

<!-- 照片数据（JSON，供 PhotoViewer 读取） -->
<script type="application/json" id="gallery-photo-data" set:html={JSON.stringify(viewerPhotos)}></script>

<!-- 照片查看器 -->
<PhotoViewer />