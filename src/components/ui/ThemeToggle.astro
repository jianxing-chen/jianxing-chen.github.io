---
// ThemeToggle - Sun/Moon icon toggle for dark mode
---

<button
  type="button"
  aria-label="Toggle dark mode"
  class="theme-toggle relative inline-flex items-center justify-center w-9 h-9 rounded-lg
         text-text-light dark:text-text-dark
         hover:bg-black/5 dark:hover:bg-white/10
         transition-colors duration-200 cursor-pointer"
>
  <!-- Sun icon (shown in dark mode) -->
  <svg
    class="theme-icon sun-icon absolute w-5 h-5 transition-all duration-300"
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <circle cx="12" cy="12" r="5"></circle>
    <line x1="12" y1="1" x2="12" y2="3"></line>
    <line x1="12" y1="21" x2="12" y2="23"></line>
    <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
    <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
    <line x1="1" y1="12" x2="3" y2="12"></line>
    <line x1="21" y1="12" x2="23" y2="12"></line>
    <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
    <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
  </svg>
  <!-- Moon icon (shown in light mode) -->
  <svg
    class="theme-icon moon-icon absolute w-5 h-5 transition-all duration-300"
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
  </svg>
</button>

<style>
  /* Light mode: show moon, hide sun */
  .sun-icon {
    opacity: 0;
    transform: rotate(-90deg) scale(0);
  }
  .moon-icon {
    opacity: 1;
    transform: rotate(0deg) scale(1);
  }

  /* Dark mode: show sun, hide moon */
  :global(.dark) .sun-icon {
    opacity: 1;
    transform: rotate(0deg) scale(1);
  }
  :global(.dark) .moon-icon {
    opacity: 0;
    transform: rotate(90deg) scale(0);
  }
</style>

<script>
  function initThemeToggle() {
    const btns = document.querySelectorAll<HTMLButtonElement>('.theme-toggle');
    if (btns.length === 0) return;
    const isHomepage = document.body.dataset.homepage === 'true';
    const managedOverlaySelector = '.theme-overlay[data-managed-theme-overlay="true"]';
    const windowWithThemeState = window as Window & {
      __themeToggleMediaBound?: boolean;
      __themeToggleOverlayObserverBound?: boolean;
      __themeToggleSyncOverlay?: () => void;
    };

    function updateAllAriaPressed() {
      const isDark = document.documentElement.classList.contains('dark');
      btns.forEach((b) => b.setAttribute('aria-pressed', String(isDark)));
    }

    function getManagedOverlay() {
      return document.querySelector<HTMLDivElement>(managedOverlaySelector);
    }

    function ensureManagedOverlay() {
      let overlay = getManagedOverlay();
      if (!overlay) {
        overlay = document.createElement('div');
        overlay.className = 'theme-overlay';
        overlay.dataset.managedThemeOverlay = 'true';
        overlay.style.opacity = '0';
      }
      if (!overlay.isConnected) {
        document.body.appendChild(overlay);
      }
      return overlay;
    }

    function syncThemeOverlay() {
      const isDark = document.documentElement.classList.contains('dark');
      const overlay = getManagedOverlay();

      if (!isHomepage) {
        overlay?.remove();
        return;
      }

      const managedOverlay = overlay ?? ensureManagedOverlay();

      if (isDark) {
        managedOverlay.style.opacity = '1';
        return;
      }

      managedOverlay.style.opacity = '0';
    }

    windowWithThemeState.__themeToggleSyncOverlay = syncThemeOverlay;

    updateAllAriaPressed();

    btns.forEach((btn) => {
      if (btn.dataset.themeToggleBound === 'true') return;
      btn.dataset.themeToggleBound = 'true';
      btn.addEventListener('click', () => {
        const isDark = document.documentElement.classList.toggle('dark');
        localStorage.setItem('theme', isDark ? 'dark' : 'light');
        updateAllAriaPressed();
        syncThemeOverlay();
        queueMicrotask(syncThemeOverlay);
        requestAnimationFrame(() => syncThemeOverlay());
      });
    });

    // 初始化：如果当前是暗色，立即添加蒙版
    syncThemeOverlay();

    if (!windowWithThemeState.__themeToggleOverlayObserverBound) {
      const overlayObserver = new MutationObserver(() => {
        windowWithThemeState.__themeToggleSyncOverlay?.();
      });

      overlayObserver.observe(document.documentElement, {
        attributes: true,
        attributeFilter: ['class'],
      });

      overlayObserver.observe(document.body, {
        attributes: true,
        attributeFilter: ['data-homepage'],
        childList: true,
      });

      windowWithThemeState.__themeToggleOverlayObserverBound = true;
    }

    // Listen for system theme changes when user has no manual preference
    if (!windowWithThemeState.__themeToggleMediaBound) {
      const mediaQuery = window.matchMedia('(prefers-color-scheme: dark)');
      mediaQuery.addEventListener('change', (e) => {
        if (localStorage.getItem('theme')) return;
        if (e.matches) {
          document.documentElement.classList.add('dark');
        } else {
          document.documentElement.classList.remove('dark');
        }
        updateAllAriaPressed();
        syncThemeOverlay();
      });
      windowWithThemeState.__themeToggleMediaBound = true;
    }
  }

  // Run on initial load
  initThemeToggle();

  // Re-run after Astro page transitions
  document.addEventListener('astro:after-swap', initThemeToggle);
</script>
