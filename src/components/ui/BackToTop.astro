---
/**
 * BackToTop.astro — 回到顶部浮动按钮
 * 当用户向下滚动超过 300px 时显示，点击后平滑滚动到顶部。
 * 放置于 BaseLayout 中，所有非首页页面皆可使用。
 *
 * 结构：外层 wrapper 控制显示/隐藏（opacity），内层 button 只负责 hover 效果，
 * 避免 JS 内联 transform 与 CSS hover transform 冲突导致跳变。
 */
---

<div
  id="back-to-top-wrapper"
  class="fixed bottom-6 right-6 z-50
         opacity-0 pointer-events-none
         transition-opacity duration-300 ease-out"
>
  <button
    id="back-to-top"
    class="flex items-center justify-center
           w-10 h-10 rounded-full
           bg-white/80 dark:bg-slate-800/80
           border border-slate-200/60 dark:border-white/10
           text-text-light/60 dark:text-text-dark/60
           shadow-md backdrop-blur-md
           transition-all duration-300 ease-out
           hover:text-primary-light dark:hover:text-primary-dark
           hover:border-primary-light/40 dark:hover:border-primary-dark/40
           hover:shadow-lg hover:-translate-y-1
           focus-visible:opacity-100 focus-visible:pointer-events-auto"
    aria-label="Scroll to top"
    title="Back to top"
  >
    <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5"
         viewBox="0 0 24 24" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 15.75l7.5-7.5 7.5 7.5" />
    </svg>
  </button>
</div>

<script>
  function initBackToTop() {
    const wrapper = document.getElementById('back-to-top-wrapper');
    const btn = wrapper?.querySelector('#back-to-top');
    if (!wrapper || !btn || wrapper.dataset.btopInit) return;
    wrapper.dataset.btopInit = 'true';

    let ticking = false;

    function update() {
      const show = window.scrollY > 300;
      if (show) {
        wrapper.style.opacity = '1';
        wrapper.style.pointerEvents = 'auto';
      } else {
        wrapper.style.opacity = '0';
        wrapper.style.pointerEvents = 'none';
      }
      ticking = false;
    }

    window.addEventListener('scroll', () => {
      if (!ticking) {
        requestAnimationFrame(update);
        ticking = true;
      }
    }, { passive: true });

    btn.addEventListener('click', () => {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  }

  initBackToTop();
  document.addEventListener('astro:after-swap', initBackToTop);
</script>
