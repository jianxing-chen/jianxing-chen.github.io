---
import { languages, getLocalizedPath } from '@/i18n/ui';

interface Props {
  lang: string;
}

const { lang } = Astro.props;
const currentUrl = Astro.url;
const targetLang = lang === 'en' ? 'zh' : 'en';
const pathname = currentUrl.pathname;
const pathWithoutLocale = lang === 'zh'
  ? pathname.replace(/^\/zh(?=\/|$)/, '') || '/'
  : pathname;
const normalizedPath = pathWithoutLocale.startsWith('/') ? pathWithoutLocale : `/${pathWithoutLocale}`;
const targetUrl = getLocalizedPath(normalizedPath, targetLang);

const displayLang = lang === 'en' ? 'EN' : '中';
const targetDisplayLang = targetLang === 'en' ? 'EN' : '中';
---

<a
  href={targetUrl}
  class="inline-flex items-center justify-center w-9 h-9 rounded-lg
         text-sm font-medium
         text-text-light dark:text-text-dark
         hover:bg-black/5 dark:hover:bg-white/10
         transition-colors duration-200"
  aria-label={`Switch to ${languages[targetLang]}`}
>
  {targetDisplayLang}
</a>
