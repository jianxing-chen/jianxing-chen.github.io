---
/**
 * 国家图库详情组件
 * 功能：渲染单个国家的完整照片列表，提供地区筛选。桌面端为 JS 贪心算法 flex masonry（4列），
 *       移动端为 CSS columns 回退。支持自定义 PhotoViewer 全屏查看。
 * 输入：单个国家的照片数组与语言代码。
 * 输出：支持地区过滤的瀑布流图库 + 全屏照片查看器。
 * 用法示例：<GalleryGrid photos={countryPhotos} lang="en" />
 */

import { getGalleryThumbnail, getGalleryFullSize } from '@/utils/cloudinary';
import { buildCountryDetail, type GalleryPhoto } from '@/utils/gallery';
import { computeMasonryLayout } from '@/utils/masonry';
import PhotoViewer from '@/components/interactive/PhotoViewer.astro';

interface Props {
  photos: GalleryPhoto[];
  lang: string;
}

const { photos, lang } = Astro.props;
const { regions } = buildCountryDetail(photos, lang);
const allRegionsLabel = lang === 'zh' ? '全部地区' : 'All Regions';
const masonryColumns = 4;

// 预计算 masonry 布局
const columns = computeMasonryLayout(photos, masonryColumns);

// 序列化照片数据供 PhotoViewer 使用
const viewerPhotos = photos.map((p) => ({
  id: p.id,
  src: getGalleryFullSize(p.cloudinaryId),
  width: p.width,
  height: p.height,
  title: p.title[lang as keyof typeof p.title] || p.title.en,
  description: p.description[lang as keyof typeof p.description] || p.description.en,
  location: p.location[lang as keyof typeof p.location] || p.location.en,
  region: p.region[lang as keyof typeof p.region] || p.region.en,
  tags: p.tags,
}));
---

<div id="country-gallery" class="gallery-detail">
  {regions.length > 1 && (
    <div class="gallery-region-filters" data-gallery-region-filters>
      <button class="gallery-region-filter is-active" data-region="all" type="button">
        {allRegionsLabel}
      </button>
      {regions.map((region) => (
        <button class="gallery-region-filter" data-region={region.key} type="button">
          {region.display}
        </button>
      ))}
    </div>
  )}

  <!-- 桌面端：flex 多列 masonry -->
  <div class="gallery-masonry gallery-masonry--desktop">
    {columns.map((col) => (
      <div class="gallery-masonry__column">
        {col.items.map((photo) => (
          <button
            id={`photo-${photo.id}`}
            data-photo-id={photo.id}
            data-region={photo.region.en}
            class="gallery-card group"
            type="button"
            aria-label={`${photo.title[lang as keyof typeof photo.title] || photo.title.en} — ${photo.region[lang as keyof typeof photo.region] || photo.region.en}`}
          >
            <img
              src={getGalleryThumbnail(photo.cloudinaryId)}
              alt={photo.title[lang as keyof typeof photo.title] || photo.title.en}
              width={photo.width}
              height={photo.height}
              loading="lazy"
              class="gallery-card__image"
              style={`aspect-ratio:${photo.width}/${photo.height}`}
            />
            <div class="gallery-card__overlay">
              <p class="gallery-card__eyebrow">
                {photo.region[lang as keyof typeof photo.region] || photo.region.en}
              </p>
              <h3 class="gallery-card__title">
                {photo.title[lang as keyof typeof photo.title] || photo.title.en}
              </h3>
            </div>
          </button>
        ))}
      </div>
    ))}
  </div>

  <!-- 移动端：CSS columns 回退 -->
  <div class="gallery-masonry gallery-masonry--mobile">
    {photos.map((photo) => (
      <button
        data-photo-id={photo.id}
        data-region={photo.region.en}
        class="gallery-card group"
        type="button"
        aria-label={`${photo.title[lang as keyof typeof photo.title] || photo.title.en}`}
      >
        <img
          src={getGalleryThumbnail(photo.cloudinaryId)}
          alt={photo.title[lang as keyof typeof photo.title] || photo.title.en}
          width={photo.width}
          height={photo.height}
          loading="lazy"
          class="gallery-card__image"
          style={`aspect-ratio:${photo.width}/${photo.height}`}
        />
        <div class="gallery-card__overlay">
          <p class="gallery-card__eyebrow">
            {photo.region[lang as keyof typeof photo.region] || photo.region.en}
          </p>
          <h3 class="gallery-card__title">
            {photo.title[lang as keyof typeof photo.title] || photo.title.en}
          </h3>
        </div>
      </button>
    ))}
  </div>
</div>

<!-- 照片数据（JSON，供 PhotoViewer 读取） -->
<script type="application/json" id="gallery-photo-data" set:html={JSON.stringify(viewerPhotos)}></script>

<!-- 照片查看器 -->
<PhotoViewer />

<script>
  // ── 地区筛选（筛选后切换为 CSS Grid 从左到右、从上到下）──
  const filterBar = document.querySelector('[data-gallery-region-filters]');
  if (filterBar) {
    filterBar.addEventListener('click', (e: Event) => {
      const button = (e.target as HTMLElement).closest('.gallery-region-filter') as HTMLButtonElement | null;
      if (!button) return;

      const region = button.dataset.region;

      // 更新 active 状态
      filterBar.querySelectorAll('.gallery-region-filter').forEach((btn) => btn.classList.remove('is-active'));
      button.classList.add('is-active');

      const gallery = document.getElementById('country-gallery')!;
      const masonryDesktop = gallery.querySelector('.gallery-masonry--desktop') as HTMLElement;

      // "全部地区" → 恢复原始 greedy masonry
      if (!region || region === 'all') {
        window.location.reload();
        return;
      }

      // 首次筛选：将列内卡片摊平到桌面 masonry 容器中，切换为 CSS Grid
      if (!gallery.classList.contains('is-filtered')) {
        const cols = [...masonryDesktop.querySelectorAll('.gallery-masonry__column')];
        const desktopCards = cols.flatMap((col) => [...col.children] as HTMLElement[]);
        masonryDesktop.innerHTML = '';
        desktopCards.forEach((card) => masonryDesktop.appendChild(card));
        gallery.classList.add('is-filtered');
      }

      // 筛选卡片（只操作桌面 masonry 内的卡片，不碰移动端 fallback）
      const cards = [...masonryDesktop.children] as HTMLElement[];
      cards.forEach((card) => {
        card.hidden = card.dataset.region !== region;
      });
    });
  }
</script>
