---
/**
 * 国家图库详情组件
 * 功能：渲染单个国家的完整照片列表，在页内提供地区筛选，并保留 PhotoSwipe 浏览体验。
 * 输入：单个国家的照片数组与语言代码。
 * 输出：支持地区过滤的瀑布流图库。
 * 用法示例：<GalleryGrid photos={countryPhotos} lang="en" />
 */

import { getGalleryThumbnail, getGalleryFullSize } from '@/utils/cloudinary';
import { buildCountryDetail, type GalleryPhoto } from '@/utils/gallery';

interface Props {
  photos: GalleryPhoto[];
  lang: string;
}

const { photos, lang } = Astro.props;
const { regions } = buildCountryDetail(photos, lang);
const allRegionsLabel = lang === 'zh' ? '全部地区' : 'All Regions';
---

<div id="country-gallery" class="gallery-detail">
  {regions.length > 1 && (
    <div class="gallery-region-filters" data-gallery-region-filters>
      <button class="gallery-region-filter is-active" data-region="all" type="button">
        {allRegionsLabel}
      </button>
      {regions.map((region) => (
        <button class="gallery-region-filter" data-region={region.key} type="button">
          {region.display}
        </button>
      ))}
    </div>
  )}

  <div class="gallery-masonry gallery-masonry--detail">
    {photos.map((photo) => (
      <a
        id={`photo-${photo.id}`}
        href={getGalleryFullSize(photo.cloudinaryId)}
        data-pswp-width={photo.width}
        data-pswp-height={photo.height}
        data-region={photo.region.en}
        class="gallery-card group scroll-mt-20"
      >
        <img
          src={getGalleryThumbnail(photo.cloudinaryId)}
          alt={photo.title[lang as keyof typeof photo.title] || photo.title.en}
          width={photo.width}
          height={photo.height}
          loading="lazy"
          class="gallery-card__image"
        />
        <div class="gallery-card__overlay">
          <p class="gallery-card__eyebrow">
            {photo.region[lang as keyof typeof photo.region] || photo.region.en}
          </p>
          <h3 class="gallery-card__title">
            {photo.title[lang as keyof typeof photo.title] || photo.title.en}
          </h3>
        </div>
      </a>
    ))}
  </div>
</div>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/photoswipe@5.4.4/dist/photoswipe.css" />

<script>
  import PhotoSwipeLightbox from 'photoswipe/lightbox';

  const lightbox = new PhotoSwipeLightbox({
    gallery: '#country-gallery',
    children: 'a.gallery-card:not([hidden])',
    pswpModule: () => import('photoswipe'),
    bgOpacity: 1,
    padding: { top: 20, bottom: 20, left: 20, right: 20 },
  });

  lightbox.on('uiRegister', function () {
    lightbox.pswp!.ui!.registerElement({
      name: 'caption',
      order: 9,
      isButton: false,
      appendTo: 'root',
      html: '',
      onInit: (el) => {
        el.style.cssText = `
          position: absolute;
          bottom: 0;
          left: 0;
          right: 0;
          padding: 16px 20px;
          background: linear-gradient(to top, rgba(0, 0, 0, 0.72), transparent);
          color: white;
          font-size: 14px;
          text-align: center;
          pointer-events: none;
        `;

        lightbox.pswp!.on('change', () => {
          const slide = lightbox.pswp!.currSlide;
          if (!slide || !slide.data.element) return;

          const eyebrow = (slide.data.element as HTMLElement).querySelector('.gallery-card__eyebrow')?.textContent || '';
          const title = (slide.data.element as HTMLElement).querySelector('.gallery-card__title')?.textContent || '';
          el.innerHTML = eyebrow
            ? `<span style="opacity:0.72;font-size:12px;letter-spacing:0.08em;text-transform:uppercase">${eyebrow}</span><br><strong>${title}</strong>`
            : `<strong>${title}</strong>`;
        });
      },
    });
  });

  lightbox.init();

  const filterBar = document.querySelector('[data-gallery-region-filters]');
  const cards = document.querySelectorAll('#country-gallery .gallery-card');

  if (filterBar) {
    const buttons = filterBar.querySelectorAll('.gallery-region-filter');

    buttons.forEach((button) => {
      button.addEventListener('click', () => {
        const region = (button as HTMLButtonElement).dataset.region;

        buttons.forEach((item) => item.classList.remove('is-active'));
        button.classList.add('is-active');

        cards.forEach((card) => {
          const cardRegion = (card as HTMLElement).dataset.region;
          (card as HTMLElement).hidden = Boolean(region && region !== 'all' && cardRegion !== region);
        });
      });
    });
  }
</script>
