---
/**
 * 国家图库详情组件
 * 功能：渲染单个国家的完整照片列表，提供地区筛选。桌面端为 JS 贪心算法 flex masonry（4列），
 *       移动端为 CSS columns 回退。支持自定义 PhotoViewer 全屏查看。
 * 输入：单个国家的照片数组与语言代码。
 * 输出：支持地区过滤的瀑布流图库 + 全屏照片查看器。
 * 用法示例：<GalleryGrid photos={countryPhotos} lang="en" />
 */

import { getGalleryFullSize } from '@/utils/cloudinary';
import { buildCountryDetail, type GalleryPhoto } from '@/utils/gallery';
import { computeMasonryLayout } from '@/utils/masonry';
import PhotoViewer from '@/components/interactive/PhotoViewer.astro';
import GalleryCard from '@/components/ui/GalleryCard.astro';

interface Props {
  photos: GalleryPhoto[];
  lang: string;
}

const { photos, lang } = Astro.props;
const { regions, photos: sortedPhotos } = buildCountryDetail(photos, lang);
const allRegionsLabel = lang === 'zh' ? '全部地区' : 'All Regions';
const masonryColumns = 4;

// 预计算 masonry 布局
const columns = computeMasonryLayout(sortedPhotos, masonryColumns);

// 序列化照片数据供 PhotoViewer 使用
const viewerPhotos = sortedPhotos.map((p) => ({
  id: p.id,
  src: getGalleryFullSize(p.cloudinaryId),
  width: p.width,
  height: p.height,
  title: p.title[lang as keyof typeof p.title] || p.title.en,
  description: p.description[lang as keyof typeof p.description] || p.description.en,
  location: p.location[lang as keyof typeof p.location] || p.location.en,
  region: p.region[lang as keyof typeof p.region] || p.region.en,
  tags: p.tags,
}));
---

<div id="country-gallery" class="gallery-detail">
  {regions.length > 1 && (
    <div class="gallery-region-filters" data-gallery-region-filters>
      <button class="gallery-region-filter is-active" data-region="all" type="button">
        {allRegionsLabel}
      </button>
      {regions.map((region) => (
        <button class="gallery-region-filter" data-region={region.key} type="button">
          {region.display}
        </button>
      ))}
    </div>
  )}

  <!-- 桌面端：flex 多列 masonry -->
  <div class="gallery-masonry gallery-masonry--desktop">
    {columns.map((col) => (
      <div class="gallery-masonry__column">
        {col.items.map((photo) => (
          <GalleryCard photo={photo} lang={lang} showId showRegion />
        ))}
      </div>
    ))}
  </div>

  <!-- 移动端：CSS columns 回退 -->
  <div class="gallery-masonry gallery-masonry--mobile">
    {sortedPhotos.map((photo) => (
      <GalleryCard photo={photo} lang={lang} showRegion />
    ))}
  </div>
</div>

<!-- 照片数据（JSON，供 PhotoViewer 读取） -->
<script type="application/json" id="gallery-photo-data" set:html={JSON.stringify(viewerPhotos)}></script>

<!-- 照片查看器 -->
<PhotoViewer />

<script>
  // ── 地区筛选：hide + 贪心重排可见卡片，消除列间空隙 ──
  (function initGalleryFilter() {
    const filterBar = document.querySelector('[data-gallery-region-filters]');
    if (!filterBar) return;

    const gallery = document.getElementById('country-gallery')!;
    const masonryDesktop = gallery.querySelector('.gallery-masonry--desktop')!;
    const cols = [...masonryDesktop.querySelectorAll<HTMLElement>('.gallery-masonry__column')];
    // 只取桌面端卡片（移动端有独立副本，CSS 控制显隐）
    const allCards = masonryDesktop.querySelectorAll<HTMLElement>('.gallery-card');

    // 保存原始列 HTML，切回 All 时直接还原
    const savedColumns = cols.map(col => col.innerHTML);

    function cardRatio(card: HTMLElement): number {
      const img = card.querySelector('img');
      if (img) {
        const w = Number(img.getAttribute('width'));
        const h = Number(img.getAttribute('height'));
        if (w && h) return h / w;
      }
      return 1;
    }

    function redistribute(visibleCards: HTMLElement[]) {
      cols.forEach(col => col.innerHTML = '');
      if (visibleCards.length === 0) return;
      const heights = new Array(cols.length).fill(0);
      for (const card of visibleCards) {
        let minIdx = 0;
        for (let i = 1; i < heights.length; i++) {
          if (heights[i] < heights[minIdx]) minIdx = i;
        }
        cols[minIdx].appendChild(card);
        heights[minIdx] += cardRatio(card);
      }
    }

    filterBar.addEventListener('click', (e: Event) => {
      const button = (e.target as HTMLElement).closest('.gallery-region-filter') as HTMLButtonElement | null;
      if (!button) return;

      const region = button.dataset.region;

      filterBar.querySelectorAll('.gallery-region-filter').forEach(btn => btn.classList.remove('is-active'));
      button.classList.add('is-active');

      // 移动端：直接 hide/show
      const mobileCards = gallery.querySelectorAll<HTMLElement>('.gallery-masonry--mobile .gallery-card');
      mobileCards.forEach(card => {
        card.hidden = !!(region && region !== 'all' && card.dataset.region !== region);
      });

      // 桌面端
      if (!region || region === 'all') {
        // 还原原始列布局
        cols.forEach((col, i) => { col.innerHTML = savedColumns[i]; });
        mobileCards.forEach(card => { card.hidden = false; });
        return;
      }

      // 筛选：收集可见卡片，贪心重排
      const visible: HTMLElement[] = [];
      allCards.forEach(card => {
        if (card.dataset.region === region) {
          card.hidden = false;
          visible.push(card);
        } else {
          card.hidden = true;
        }
      });
      redistribute(visible);
    });
  })();
</script>
