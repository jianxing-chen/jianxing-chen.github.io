---
interface Paper {
  title: string;
  authors: string[];
  journal: string;
  year: number;
  volume: string;
  pages: string;
  doi: string;
  arxiv: string;
  ads: string;
  highlight: boolean;
  type: 'first-author' | 'co-author' | 'corresponding';
}

interface Props {
  paper: Paper;
  lang: string;
}

import { useTranslations } from '@/i18n/ui';
import { SITE_CONFIG } from '@/config/site';

const { paper, lang } = Astro.props;
const t = useTranslations(lang);

const isHighlighted = paper.type === 'first-author' || paper.type === 'corresponding';
const selfPattern = SITE_CONFIG.selfPattern;

function formatAuthors(authors: string[]): { name: string; isSelf: boolean }[] {
  return authors.map((a) => ({ name: a, isSelf: a === selfPattern }));
}

const authorList = formatAuthors(paper.authors);
const adsUrl = `https://ui.adsabs.harvard.edu/abs/${paper.ads}`;
const arxivUrl = `https://arxiv.org/abs/${paper.arxiv}`;
const doiUrl = `https://doi.org/${paper.doi}`;
const pdfUrl = `https://arxiv.org/pdf/${paper.arxiv}`;
---

<article
  class:list={[
    'group relative rounded-xl p-5 transition-all duration-300',
    'bg-white/60 dark:bg-white/[0.04]',
    'border border-slate-200/80 dark:border-white/[0.06]',
    'hover:shadow-lg hover:shadow-slate-200/50 dark:hover:shadow-black/20',
    'hover:border-slate-300 dark:hover:border-white/10',
    'hover:-translate-y-0.5',
    isHighlighted && 'pl-5',
  ]}
>
  {/* Accent bar for first-author / corresponding */}
  {isHighlighted && (
    <div class="absolute left-0 top-4 bottom-4 w-[3px] rounded-full bg-primary-light dark:bg-primary-dark" />
  )}

  {/* Title */}
  <h3 class="text-[0.95rem] font-semibold leading-snug text-heading-light dark:text-heading-dark mb-2">
    {paper.title}
  </h3>

  {/* Authors */}
  <p class="text-sm text-text-light/70 dark:text-text-dark/70 mb-1.5 leading-relaxed">
    {authorList.map((author, i) => (
      <Fragment>
        {i > 0 && ', '}
        {author.isSelf ? (
          <span class="font-semibold text-primary-light dark:text-primary-dark">{author.name}</span>
        ) : (
          <span>{author.name}</span>
        )}
      </Fragment>
    ))}
  </p>

  {/* Journal info */}
  <p class="text-sm text-text-light/60 dark:text-text-dark/60 mb-3">
    <em class="not-italic font-medium text-text-light/80 dark:text-text-dark/80">{paper.journal}</em>,
    {' '}{paper.volume}, {paper.pages} ({paper.year})
    {paper.type === 'first-author' && (
      <span class="ml-2 inline-flex items-center gap-1 text-xs font-medium text-primary-light dark:text-primary-dark">
        <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
        {t('publications.first_author')}
      </span>
    )}
    {paper.type === 'corresponding' && (
      <span class="ml-2 inline-flex items-center gap-1 text-xs font-medium text-accent-light dark:text-accent-dark">
        ✦ {t('publications.corresponding')}
      </span>
    )}
  </p>

  {/* Link buttons */}
  <div class="flex flex-wrap gap-2">
    <a
      href={adsUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center gap-1 px-2.5 py-1 text-xs font-medium rounded-full
             border border-slate-200 dark:border-white/10
             text-text-light/70 dark:text-text-dark/60
             hover:bg-primary-light hover:text-white hover:border-primary-light
             dark:hover:bg-primary-dark dark:hover:text-slate-900 dark:hover:border-primary-dark
             transition-all duration-200"
    >
      <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" /></svg>
      {t('publications.ads')}
    </a>
    <a
      href={arxivUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center gap-1 px-2.5 py-1 text-xs font-medium rounded-full
             border border-slate-200 dark:border-white/10
             text-text-light/70 dark:text-text-dark/60
             hover:bg-primary-light hover:text-white hover:border-primary-light
             dark:hover:bg-primary-dark dark:hover:text-slate-900 dark:hover:border-primary-dark
             transition-all duration-200"
    >
      <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" /></svg>
      {t('publications.arxiv')}
    </a>
    <a
      href={doiUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center gap-1 px-2.5 py-1 text-xs font-medium rounded-full
             border border-slate-200 dark:border-white/10
             text-text-light/70 dark:text-text-dark/60
             hover:bg-primary-light hover:text-white hover:border-primary-light
             dark:hover:bg-primary-dark dark:hover:text-slate-900 dark:hover:border-primary-dark
             transition-all duration-200"
    >
      <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 011.242 7.244l-4.5 4.5a4.5 4.5 0 01-6.364-6.364l1.757-1.757m9.86-2.06a4.5 4.5 0 00-1.242-7.244l-4.5-4.5a4.5 4.5 0 00-6.364 6.364L4.34 8.878" /></svg>
      {t('publications.doi')}
    </a>
    <a
      href={pdfUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center gap-1 px-2.5 py-1 text-xs font-medium rounded-full
             border border-slate-200 dark:border-white/10
             text-text-light/70 dark:text-text-dark/60
             hover:bg-primary-light hover:text-white hover:border-primary-light
             dark:hover:bg-primary-dark dark:hover:text-slate-900 dark:hover:border-primary-dark
             transition-all duration-200"
    >
      <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" /></svg>
      {t('publications.pdf')}
    </a>
  </div>
</article>
