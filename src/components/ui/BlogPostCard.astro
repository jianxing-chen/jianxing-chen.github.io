---
import { getLocalizedPath, useTranslations } from '@/i18n/ui';

interface Props {
  post: {
    id: string;
    data: {
      title: string;
      date: Date;
      description: string;
      tags: string[];
      cover?: string;
      lang: string;
    };
  };
  lang: string;
}

const { post, lang } = Astro.props;
const { title, date, description, tags, cover } = post.data;
const t = useTranslations(lang);

// Extract slug from id: "en/hello-world" → "hello-world"
const slug = post.id.includes('/') ? post.id.split('/').slice(1).join('/') : post.id;

const formattedDate = new Date(date).toLocaleDateString(lang === 'zh' ? 'zh-CN' : 'en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const postUrl = getLocalizedPath(`/blog/${slug}/`, lang);

// Estimate reading time (~200 words/min for en, ~300 chars/min for zh)
---

<article
  class="group relative rounded-xl
         bg-white dark:bg-white/5
         border border-black/[0.06] dark:border-white/[0.06]
         hover:border-primary-light/30 dark:hover:border-primary-dark/30
         hover:shadow-lg hover:shadow-primary-light/5 dark:hover:shadow-primary-dark/5
         transition-all duration-300 overflow-hidden"
>
  {cover && (
    <a href={postUrl} class="block aspect-[2/1] overflow-hidden">
      <img
        src={cover}
        alt={title}
        class="w-full h-full object-cover
               group-hover:scale-105 transition-transform duration-500"
        loading="lazy"
      />
    </a>
  )}

  <div class="p-5 sm:p-6">
    <!-- Date -->
    <time
      datetime={date.toISOString()}
      class="text-xs tracking-wide uppercase
             text-text-light/50 dark:text-text-dark/50"
    >
      {formattedDate}
    </time>

    <!-- Title -->
    <h2 class="mt-2 mb-2">
      <a
        href={postUrl}
        class="text-lg font-semibold leading-snug
               text-heading-light dark:text-heading-dark
               group-hover:text-primary-light dark:group-hover:text-primary-dark
               transition-colors duration-200"
        style="font-family: 'Space Grotesk', 'Inter', sans-serif;"
      >
        {title}
      </a>
    </h2>

    <!-- Description -->
    <p class="text-sm leading-relaxed text-text-light/70 dark:text-text-dark/70
              line-clamp-2 mb-4">
      {description}
    </p>

    <!-- Tags -->
    <div class="flex flex-wrap gap-1.5">
      {tags.map((tag) => (
        <span
          class="inline-block px-2.5 py-0.5 text-xs rounded-full
                 bg-primary-light/8 dark:bg-primary-dark/10
                 text-primary-light dark:text-primary-dark
                 font-medium"
        >
          {tag}
        </span>
      ))}
    </div>
  </div>
</article>
